    "pageContent": "<div class=\"resumen-container\">\n  <div class=\"glass-card shadow-lg p-4\">\n    <div class=\"header mb-4\">\n      <h2 class=\"text-warning fw-bold\"><i class=\"bi bi-cart4\"></i> Resumen de tu Pedido</h2>\n      <p class=\"text-white-50 small\">Revisa tus productos antes de confirmar</p>\n    </div>\n\n    @if (items().length === 0) {\n      <div class=\"text-center py-5\">\n        <div class=\"empty-icon\">🍕</div>\n        <h4 class=\"text-white mt-3\">Tu carrito está vacío</h4>\n        <button class=\"btn btn-outline-warning mt-3\" (click)=\"volverAlMenu()\">Explorar Menú</button>\n      </div>\n    } @else {\n      <div class=\"items-list scroll-custom\">\n        @for (item of items(); track $index) {\n          <div class=\"item-row d-flex justify-content-between align-items-center p-3 mb-2\">\n            <div class=\"item-info\">\n              <h6 class=\"text-white mb-0\">{{ item.nombre }}</h6>\n              <span class=\"badge bg-secondary opacity-75\">{{ item.tamano }}</span>\n            </div>\n            \n            <div class=\"item-controls d-flex align-items-center gap-3\">\n              <div class=\"qty-selector d-flex align-items-center\">\n                <button class=\"btn-qty\" (click)=\"disminuir($index)\">-</button>\n                <span class=\"qty-text\">{{ item.cantidad }}</span>\n                <button class=\"btn-qty\" (click)=\"aumentar($index)\">+</button>\n              </div>\n              \n              <div class=\"price text-end\" style=\"min-width: 100px;\">\n                <div class=\"text-warning fw-bold\">${{ (item.precioUnitario * item.cantidad) | number }}</div>\n                <div class=\"text-white-50 x-small\">${{ item.precioUnitario | number }} c/u</div>\n              </div>\n\n              <button class=\"btn-remove\" (click)=\"eliminar($index)\" title=\"Quitar item\">\n                <i class=\"bi bi-trash\"></i>\n              </button>\n            </div>\n          </div>\n        }\n      </div>\n\n      <div class=\"totals-section mt-4 pt-3 border-top border-secondary border-opacity-50\">\n        <div class=\"d-flex justify-content-between text-white mb-2\">\n          <span>Subtotal ({{ totalItems() }} items)</span>\n          <span>${{ total() | number }}</span>\n        </div>\n        <div class=\"d-flex justify-content-between text-warning fw-bold fs-4\">\n          <span>TOTAL</span>\n          <span>${{ total() | number }}</span>\n        </div>\n      </div>\n\n      <div class=\"actions-grid mt-4 gap-3\">\n        <button class=\"btn btn-confirm py-3 fw-bold\" (click)=\"confirmarPedido()\">\n          CONFIRMAR PEDIDO\n        </button>\n        <div class=\"d-flex gap-2\">\n          <button class=\"btn btn-cancel flex-grow-1\" (click)=\"cancelarPedido()\">\n            CANCELAR\n          </button>\n          <button class=\"btn btn-outline-light flex-grow-1\" (click)=\"volverAlMenu()\">\n            SEGUIR COMPRANDO\n          </button>\n        </div>\n      </div>\n    }\n  </div>\n</div>\n",
