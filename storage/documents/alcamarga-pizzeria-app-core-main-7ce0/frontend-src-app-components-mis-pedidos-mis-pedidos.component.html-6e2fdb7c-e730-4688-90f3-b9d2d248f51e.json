    "pageContent": "<div class=\"mis-pedidos-container\">\n  <div class=\"header\">\n    <h1>Mis Pedidos</h1>\n    <p>Sigue el rastro de tus pizzas favoritas</p>\n  </div>\n\n  <div *ngIf=\"cargando\" class=\"loading\">\n    <div class=\"spinner\"></div>\n    <p>Cargando tus pedidos...</p>\n  </div>\n\n  <div *ngIf=\"!cargando && pedidos.length === 0\" class=\"empty-state\">\n    <i class=\"icon-pizza-sad\"></i>\n    <h3>Aún no tienes pedidos</h3>\n    <p>¿Qué tal si pides algo delicioso ahora?</p>\n    <button routerLink=\"/menu\" class=\"btn-primary\">Ver Menú</button>\n  </div>\n\n  <div *ngIf=\"!cargando && pedidos.length > 0\" class=\"pedidos-list\">\n    <div *ngFor=\"let pedido of pedidos\" class=\"pedido-card\">\n      <div class=\"pedido-header\">\n        <span class=\"pedido-id\">Orden #{{ pedido.id }}</span>\n        <span [class]=\"'badge ' + getBadgeClass(pedido.estado)\">{{ pedido.estado }}</span>\n      </div>\n      \n      <div class=\"pedido-body\">\n        <div class=\"info-row\">\n          <span class=\"label\">Fecha:</span>\n          <span class=\"value\">{{ pedido.fecha_hora }}</span>\n        </div>\n        <div class=\"info-row\">\n          <span class=\"label\">Productos:</span>\n          <div class=\"articulos-mini\">\n            <span *ngFor=\"let art of pedido.articulos\">{{ art.cantidad }}x {{ art.nombre }} ({{ art.tamano }})</span>\n          </div>\n        </div>\n        <div class=\"info-row total-row\">\n          <span class=\"label\">Total:</span>\n          <span class=\"value total\">{{ pedido.total | currency:'USD':'symbol':'1.0-0' }}</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"footer-actions\">\n    <button routerLink=\"/menu\" class=\"btn-secondary\">Volver al Menú</button>\n  </div>\n</div>\n",
