    "pageContent": "<!-- Formulario de registro de nuevos usuarios | User registration form -->\n<!-- Autor: Camilo Martinez | Fecha: 15/04/2026 -->\n\n<div class=\"login-wrapper d-flex align-items-center justify-content-center min-vh-100\">\n  <div class=\"login-card glass-effect\">\n\n    <!-- Encabezado con gradiente dorado | Header with gold gradient -->\n    <div class=\"login-header text-center py-4\">\n      <div class=\"logo-icon mb-2\">🍕</div>\n      <h2 class=\"mb-1\">Pizzería Core</h2>\n      <p class=\"mb-0\">Crea tu cuenta y empieza a pedir</p>\n    </div>\n\n    <div class=\"login-body\">\n\n      <!-- Alerta de error | Error alert -->\n      @if (errorMensaje) {\n        <div class=\"alert alert-error d-flex align-items-center gap-2\" role=\"alert\">\n          <span class=\"error-icon\">⚠️</span>\n          <span>{{ errorMensaje }}</span>\n        </div>\n      }\n\n      <!-- Formulario | Form -->\n      <form [formGroup]=\"formulario\" (ngSubmit)=\"registrar()\" novalidate>\n\n        <!-- Nombre completo | Full name -->\n        <div class=\"form-group mb-3\">\n          <label for=\"nombre\" class=\"form-label\">\n            <span class=\"label-icon\">👤</span>\n            Nombre completo\n          </label>\n          <input\n            id=\"nombre\"\n            type=\"text\"\n            class=\"form-control\"\n            [class.is-invalid]=\"nombre.invalid && nombre.touched\"\n            formControlName=\"nombre\"\n            placeholder=\"Tu nombre\"\n            autocomplete=\"name\">\n          @if (nombre.invalid && nombre.touched) {\n            <div class=\"invalid-feedback d-block\">\n              @if (nombre.errors?.['required']) {\n                <small>El nombre es obligatorio.</small>\n              }\n              @if (nombre.errors?.['minlength']) {\n                <small>Debe tener al menos 2 caracteres.</small>\n              }\n            </div>\n          }\n        </div>\n\n        <!-- Email -->\n        <div class=\"form-group mb-3\">\n          <label for=\"email\" class=\"form-label\">\n            <span class=\"label-icon\">📧</span>\n            Correo electrónico\n          </label>\n          <input\n            id=\"email\"\n            type=\"email\"\n            class=\"form-control\"\n            [class.is-invalid]=\"email.invalid && email.touched\"\n            formControlName=\"email\"\n            placeholder=\"usuario@ejemplo.com\"\n            autocomplete=\"email\">\n          @if (email.invalid && email.touched) {\n            <div class=\"invalid-feedback d-block\">\n              @if (email.errors?.['required']) {\n                <small>El correo es obligatorio.</small>\n              }\n              @if (email.errors?.['email']) {\n                <small>Ingresa un correo válido.</small>\n              }\n            </div>\n          }\n        </div>\n\n        <!-- Contraseña | Password -->\n        <div class=\"form-group mb-4\">\n          <label for=\"contrasena\" class=\"form-label\">\n            <span class=\"label-icon\">🔐</span>\n            Contraseña\n          </label>\n          <input\n            id=\"contrasena\"\n            type=\"password\"\n            class=\"form-control\"\n            [class.is-invalid]=\"contrasena.invalid && contrasena.touched\"\n            formControlName=\"contrasena\"\n            placeholder=\"Mínimo 6 caracteres\"\n            autocomplete=\"new-password\">\n          @if (contrasena.invalid && contrasena.touched) {\n            <div class=\"invalid-feedback d-block\">\n              @if (contrasena.errors?.['required']) {\n                <small>La contraseña es obligatoria.</small>\n              }\n              @if (contrasena.errors?.['minlength']) {\n                <small>Debe tener al menos 6 caracteres.</small>\n              }\n            </div>\n          }\n        </div>\n\n        <!-- Botón submit | Submit button -->\n        <button\n          type=\"submit\"\n          class=\"btn-submit w-100 fw-bold py-3\"\n          [disabled]=\"enviando\">\n          @if (enviando) {\n            <span class=\"spinner-border spinner-border-sm me-2\" role=\"status\"></span>\n          }\n          {{ enviando ? 'Creando cuenta...' : 'Crear Cuenta' }}\n        </button>\n\n      </form>\n\n      <!-- Link a login | Login link -->\n      <p class=\"text-center mt-4 mb-0 text-muted small\">\n        ¿Ya tienes cuenta?\n        <a routerLink=\"/login\" class=\"fw-semibold link-gold\">Inicia sesión aquí</a>\n      </p>\n\n    </div>\n  </div>\n</div>\n",
