    "pageContent": "<!-- Contenedor principal del inventario | Main inventory container -->\n<div class=\"inventario-container\">\n  <h2 class=\"inventario-title\">Inventario de Insumos</h2>\n  \n  <div class=\"table-wrapper\">\n    <table class=\"inventario-table\">\n      <thead>\n        <tr>\n          <th>Nombre</th>\n          <th>Cantidad Actual</th>\n          <th>Unidad</th>\n          <th>Estado</th>\n          <th>Acciones</th>\n        </tr>\n      </thead>\n      <tbody>\n        <!-- Iteración de tabla con ngFor sobre la señal insumos | Table iteration using ngFor over insumos signal -->\n        <tr *ngFor=\"let insumo of insumos()\">\n          <td>{{ insumo.nombre }}</td>\n          <td>\n            <div *ngIf=\"editandoId === insumo.id; else mostrarCantidad\" class=\"d-flex align-items-center\">\n              <input type=\"number\" class=\"form-control form-control-sm text-center me-2 bg-dark border-warning\" style=\"width: 80px; color: white !important; font-weight: bold;\" [(ngModel)]=\"cantidadEditada\" />\n              <button class=\"btn btn-sm btn-success p-1\" (click)=\"guardarEdicion(insumo.id)\">✅</button>\n              <button class=\"btn btn-sm btn-outline-light p-1 ms-1\" (click)=\"cancelarEdicion()\">❌</button>\n            </div>\n            <ng-template #mostrarCantidad>\n              <span class=\"d-flex align-items-center fw-bold text-crema\" style=\"cursor: pointer; transition: 0.2s;\" (click)=\"iniciarEdicion(insumo)\" title=\"Clic para editar\">\n                {{ insumo.cantidad_actual }} \n                <span class=\"ms-2 opacity-50 small\">✏️</span>\n              </span>\n            </ng-template>\n          </td>\n          <td>{{ insumo.unidad_medida }}</td>\n          <td>\n            <!-- Alerta visual de stock | Stock visual alert -->\n            <span *ngIf=\"insumo.cantidad_actual < insumo.stock_minimo\" class=\"badge danger\">Bajo Stock</span>\n            <span *ngIf=\"insumo.cantidad_actual >= insumo.stock_minimo\" class=\"badge ok\">Óptimo</span>\n          </td>\n          <td class=\"text-center\">\n            <button class=\"btn btn-sm btn-outline-danger\" title=\"Eliminar Insumo\" (click)=\"eliminarInsumo(insumo.id)\">🗑️</button>\n          </td>\n        </tr>\n\n        <!-- Diseño en caso de no haber datos | UI for no data case -->\n        <tr *ngIf=\"insumos().length === 0\">\n          <td colspan=\"5\" class=\"no-data text-center p-4\">No se encontraron insumos cargados.</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n  \n  <!-- Add new Item UI -->\n  <div class=\"mt-4\">\n    <button class=\"btn btn-warning fw-bold mb-3\" (click)=\"toggleNuevoInsumo()\" *ngIf=\"!nuevoInsumoVisibilidad\">➕ Nuevo Insumo</button>\n    \n    <div class=\"card p-3 border-warning bg-dark\" *ngIf=\"nuevoInsumoVisibilidad\" style=\"max-width: 800px; border-radius: 8px;\">\n      <h5 class=\"text-crema mb-3\">Registrar Insumo</h5>\n      <div class=\"row g-2 align-items-end\">\n        <div class=\"col-md-3\">\n          <label class=\"form-label text-white small mb-1\">Nombre</label>\n          <input class=\"form-control form-control-sm bg-dark text-white border-secondary\" placeholder=\"Ej: Peperoni\" [(ngModel)]=\"nuevoInsumo.nombre\">\n        </div>\n        <div class=\"col-md-2\">\n          <label class=\"form-label text-white small mb-1\">Cantidad Inicial</label>\n          <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevoInsumo.cantidad_actual\">\n        </div>\n        <div class=\"col-md-2\">\n          <label class=\"form-label text-white small mb-1\">Unidad</label>\n          <input class=\"form-control form-control-sm bg-dark text-white border-secondary\" placeholder=\"kg, L, uds\" [(ngModel)]=\"nuevoInsumo.unidad_medida\">\n        </div>\n        <div class=\"col-md-2\">\n          <label class=\"form-label text-white small mb-1\">Stock Mín.</label>\n          <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevoInsumo.stock_minimo\">\n        </div>\n        <div class=\"col-md-3 d-flex gap-2\">\n          <button class=\"btn btn-sm btn-success fw-bold w-100\" (click)=\"agregarInsumo()\">Guardar</button>\n          <button class=\"btn btn-sm btn-outline-light w-100\" (click)=\"toggleNuevoInsumo()\">X</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n",
