    "wordCount": 2468,
    "pageContent": "<style>\n  .menu-page {\n    /* Usamos filter: brightness para aclarar la imagen sin capas negras */\n    background-image: url('/assets/images/pizzeria-app-core.jpg');\n    background-size: cover;\n    background-position: center;\n    background-attachment: fixed;\n    min-height: 100vh;\n    /* Ajusta este valor (1.2 es más luz, 0.8 es menos) */\n    filter: brightness(1.1); \n  }\n  \n  /* Contenedor para que el contenido NO se aclare con el fondo */\n  .content-wrapper { filter: brightness(1) !important; position: relative; z-index: 1; }\n\n  .glass-card { \n    background: rgba(0, 0, 0, 0.75); /* Tarjeta oscura para que el texto blanco resalte */\n    backdrop-filter: blur(10px); \n    border: 1px solid rgba(255,255,255,0.2); \n    border-radius: 20px;\n  }\n</style>\n\n<div class=\"menu-page\">\n  <div class=\"content-wrapper\">\n    <nav class=\"navbar navbar-dark bg-dark bg-opacity-75 p-3\">\n      <div class=\"container d-flex justify-content-between\">\n        <span class=\"navbar-brand fw-bold text-warning\">🍕 Pizzería Core</span>\n        <div class=\"d-flex gap-2\">\n          @if (usuarioActual?.rol === 'admin') {\n            <button class=\"btn btn-warning btn-sm fw-bold\" (click)=\"irAlDashboard()\">📊 Dashboard</button>\n          }\n          @if (estaAutenticado()) {\n            <button class=\"btn btn-warning btn-sm fw-bold position-relative me-2\" (click)=\"router.navigate(['/resumen'])\">\n              🛒 Ver Carrito\n              @if (cartService.totalArticulos() > 0) {\n                <span class=\"position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light\">\n                  {{ cartService.totalArticulos() }}\n                </span>\n              }\n            </button>\n            <button class=\"btn btn-outline-warning btn-sm fw-bold me-2\" (click)=\"router.navigate(['/mis-pedidos'])\">\n              📋 Mis Pedidos\n            </button>\n            <button class=\"btn btn-outline-light btn-sm\" (click)=\"auth.cerrarSesion()\">Salir</button>\n          } @else {\n            <button class=\"btn btn-outline-light btn-sm\" (click)=\"router.navigate(['/login'])\">Iniciar Sesión</button>\n          }\n        </div>\n      </div>\n    </nav>\n\n    <div class=\"container py-5 text-center\">\n      <!-- Alerta de éxito flotante -->\n      @if (mensajeExito()) {\n        <div class=\"alert alert-success position-fixed top-0 start-50 translate-middle-x mt-3 shadow-lg border-2 border-success\" \n             style=\"z-index: 2000; min-width: 300px; animation: fadeInDown 0.4s both;\">\n          <div class=\"d-flex align-items-center justify-content-center gap-2\">\n            <span>🎉</span>\n            <span class=\"fw-bold\">{{ mensajeExito() }}</span>\n          </div>\n        </div>\n      }\n\n      <h1 class=\"display-3 fw-bold mb-5 text-white\" style=\"text-shadow: 0px 4px 10px rgba(0,0,0,0.9)\">Nuestro Menú</h1>\n\n      @if (usuarioActual?.rol === 'admin') {\n        @if (mostrarFormulario) {\n          <div class=\"menu-form bg-dark bg-opacity-75 p-4 rounded border border-warning shadow-lg text-start mx-auto mt-4\" style=\"max-width: 800px; display: inline-block;\">\n            <h3 class=\"text-warning mb-3\">✏️ Editar Pizza</h3>\n            \n            <div class=\"row g-2 align-items-end\">\n              <div class=\"col-md-3\">\n                <label class=\"form-label text-white small mb-1\">Nombre</label>\n                <input class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.nombre\">\n              </div>\n              <div class=\"col-md-6\">\n                <label class=\"form-label text-white small mb-1\">Descripción</label>\n                <input class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.descripcion\">\n              </div>\n              <div class=\"col-md-3\">\n                <label class=\"form-label text-white small mb-1\">Categoría</label>\n                <select class=\"form-select form-select-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.categoria\">\n                  <option *ngFor=\"let cat of categoriasPosibles\" [value]=\"cat\">{{cat}}</option>\n                </select>\n              </div>\n              \n              <div class=\"col-md-3\" *ngIf=\"mostrarCampoPrecioForm(1)\">\n                <label class=\"form-label text-warning small mb-1\">{{ getEtiquetaPrecioForm(1) }}</label>\n                <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.precio_1\" placeholder=\"$\">\n              </div>\n              <div class=\"col-md-3\" *ngIf=\"mostrarCampoPrecioForm(2)\">\n                <label class=\"form-label text-warning small mb-1\">{{ getEtiquetaPrecioForm(2) }}</label>\n                <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.precio_2\" placeholder=\"$\">\n              </div>\n              <div class=\"col-md-3\" *ngIf=\"mostrarCampoPrecioForm(3)\">\n                <label class=\"form-label text-warning small mb-1\">{{ getEtiquetaPrecioForm(3) }}</label>\n                <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.precio_3\" placeholder=\"$\">\n              </div>\n\n              <div class=\"col-md-3 d-flex gap-2 ms-auto mt-3\">\n                <button class=\"btn btn-sm btn-success fw-bold w-100\" (click)=\"guardarPizza()\">Guardar</button>\n                <button type=\"button\" class=\"btn btn-sm btn-outline-light w-100\" (click)=\"cancelarFormulario()\">Cancelar</button>\n              </div>\n            </div>\n          </div>\n        }\n      }\n      <div class=\"row g-4 text-start\">\n        @for (pizza of pizzas(); track pizza.id) {\n          <div class=\"col-md-6 col-lg-4\">\n            <div class=\"glass-card p-4 h-100 shadow-lg text-white\">\n              <div class=\"d-flex justify-content-between align-items-center mb-3 border-bottom border-secondary pb-2\">\n                <h3 class=\"text-warning fw-bold h4 mb-0\">{{ pizza.nombre }}</h3>\n                @if (usuarioActual?.rol === 'admin') {\n                  <div class=\"d-flex gap-2\">\n                    <button class=\"btn btn-sm btn-outline-info\" (click)=\"modificarPizza(pizza.id)\">✏️</button>\n                  </div>\n                }\n              </div>\n              <p class=\"small opacity-75 mb-4\">{{ pizza.descripcion }}</p>\n\n              <!-- Precio 1 -->\n              <div class=\"d-flex justify-content-between align-items-center mb-2 p-2 rounded bg-white bg-opacity-10 border border-white border-opacity-10\" *ngIf=\"pizza.precio_1\">\n                <span class=\"small\">{{ getEtiquetasPrecio(pizza.categoria || 'Pizza')[0] }}: <b class=\"text-warning\">${{ pizza.precio_1 | number }}</b></span>\n                @if (usuarioActual?.rol !== 'admin') {\n                  <button class=\"btn btn-sm transition-all\" \n                          [class.btn-warning]=\"!agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[0]]\"\n                          [class.btn-success]=\"agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[0]]\"\n                          (click)=\"agregarAlCarrito(pizza, getEtiquetasPrecio(pizza.categoria || 'Pizza')[0], pizza.precio_1)\">\n                    {{ agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[0]] ? '✅ ¡Agregado!' : '🛒 Comprar' }}\n                  </button>\n                }\n              </div>\n\n              <!-- Precio 2 -->\n              <div class=\"d-flex justify-content-between align-items-center mb-2 p-2 rounded bg-white bg-opacity-10 border border-white border-opacity-10\" *ngIf=\"pizza.precio_2\">\n                <span class=\"small\">{{ getEtiquetasPrecio(pizza.categoria || 'Pizza')[1] }}: <b class=\"text-warning\">${{ pizza.precio_2 | number }}</b></span>\n                @if (usuarioActual?.rol !== 'admin') {\n                  <button class=\"btn btn-sm transition-all\" \n                          [class.btn-warning]=\"!agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[1]]\"\n                          [class.btn-success]=\"agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[1]]\"\n                          (click)=\"agregarAlCarrito(pizza, getEtiquetasPrecio(pizza.categoria || 'Pizza')[1], pizza.precio_2)\">\n                    {{ agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[1]] ? '✅ ¡Agregado!' : '🛒 Comprar' }}\n                  </button>\n                }\n              </div>\n\n              <!-- Precio 3 -->\n              <div class=\"d-flex justify-content-between align-items-center mb-2 p-2 rounded bg-white bg-opacity-10 border border-white border-opacity-10\" *ngIf=\"pizza.precio_3\">\n                <span class=\"small\">{{ getEtiquetasPrecio(pizza.categoria || 'Pizza')[2] }}: <b class=\"text-warning\">${{ pizza.precio_3 | number }}</b></span>\n                @if (usuarioActual?.rol !== 'admin') {\n                  <button class=\"btn btn-sm transition-all\" \n                          [class.btn-warning]=\"!agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[2]]\"\n                          [class.btn-success]=\"agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[2]]\"\n                          (click)=\"agregarAlCarrito(pizza, getEtiquetasPrecio(pizza.categoria || 'Pizza')[2], pizza.precio_3)\">\n                    {{ agregandoState()[pizza.id + '-' + getEtiquetasPrecio(pizza.categoria || 'Pizza')[2]] ? '✅ ¡Agregado!' : '🛒 Comprar' }}\n                  </button>\n                }\n              </div>\n\n\n            </div>\n          </div>\n        }\n      </div>\n    </div>\n  </div>\n</div>\n",
    "token_count_estimate": 1217
}