    "pageContent": "<div class=\"recipe-config-container\">\n  <div class=\"header\">\n    <h2>Configuración de Recetas</h2>\n    <p>Define el consumo de insumos por cada producto</p>\n  </div>\n\n  <div class=\"main-layout\">\n    <!-- Lista de Productos -->\n    <div class=\"sidebar\">\n      <h3>Productos</h3>\n      <ul class=\"pizza-list\">\n        <li *ngFor=\"let p of pizzas()\" \n            [class.active]=\"pizzaSeleccionadaId === p.id\"\n            (click)=\"seleccionarPizza(p.id)\">\n          {{ p.nombre }}\n          <span class=\"category\">{{ p.categoria }}</span>\n        </li>\n      </ul>\n    </div>\n\n    <!-- Editor de Receta -->\n    <div class=\"editor\" *ngIf=\"pizzaSeleccionadaId\">\n      <div class=\"editor-header\">\n        <h3>Receta para: <span>{{ pizzas().find(p => p.id === pizzaSeleccionadaId)?.nombre }}</span></h3>\n        <button class=\"btn-save\" (click)=\"guardarReceta()\">Guardar Cambios</button>\n      </div>\n\n      <table class=\"recipe-table\">\n        <thead>\n          <tr>\n            <th>Insumo</th>\n            <th>Cantidad</th>\n            <th>Unidad</th>\n            <th>Acciones</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr *ngFor=\"let r of recetaActual; let i = index\">\n            <td>{{ r.insumo_nombre }}</td>\n            <td>\n              <input type=\"number\" [(ngModel)]=\"r.cantidad_gastada\" class=\"qty-input\">\n            </td>\n            <td>{{ r.unidad_medida }}</td>\n            <td>\n              <button class=\"btn-delete\" (click)=\"quitarIngrediente(i)\">🗑️</button>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n\n      <!-- Agregar nuevo ingrediente -->\n      <div class=\"add-ingredient\">\n        <h4>Agregar Ingrediente</h4>\n        <div class=\"add-form\">\n          <select [(ngModel)]=\"nuevoIngrediente.insumo_id\">\n            <option [value]=\"0\">Seleccione Insumo...</option>\n            <option *ngFor=\"let ins of insumosDisponibles()\" [value]=\"ins.id\">\n              {{ ins.nombre }} ({{ ins.unidad_medida }})\n            </option>\n          </select>\n          <input type=\"number\" [(ngModel)]=\"nuevoIngrediente.cantidad_gastada\" placeholder=\"Cant.\">\n          <button (click)=\"agregarIngrediente()\">Añadir</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"no-selection\" *ngIf=\"!pizzaSeleccionadaId\">\n      <i class=\"icon-select\"></i>\n      <p>Selecciona un producto de la izquierda para editar su receta</p>\n    </div>\n  </div>\n</div>\n",
