    "pageContent": "<style>\n  .dash-container {\n    background-image: url('/assets/images/pizzeria-app-core.jpg');\n    background-size: cover;\n    background-position: center;\n    min-height: 100vh;\n    padding: 40px 20px;\n    filter: brightness(1.1);\n  }\n  .main-panel {\n    background: rgba(0, 0, 0, 0.85);\n    backdrop-filter: blur(15px);\n    border-radius: 20px;\n    color: #fff8e7;\n    padding: 30px;\n    border: 1px solid rgba(212, 175, 55, 0.3);\n  }\n  .main-panel h2 {\n    color: #d4af37;\n  }\n  .table-container {\n    background: rgba(0, 0, 0, 0.8);\n    border-radius: 15px;\n    padding: 20px;\n    margin-top: 20px;\n    border: 1px solid rgba(212, 175, 55, 0.2);\n  }\n  .table-container th {\n    color: #d4af37 !important;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n  .table-container td {\n    color: #fff8e7 !important;\n    border-bottom: 1px solid rgba(255, 248, 231, 0.1);\n  }\n  .table-container tr:hover td {\n    background: rgba(212, 175, 55, 0.05);\n  }\n</style>\n\n<div class=\"dash-container\">\n  <div class=\"container main-panel\">\n      <div class=\"d-flex justify-content-between align-items-center mb-4\">\n        <h2 class=\"fw-bold\"><span class=\"text-warning\">📦</span> Inventario de Productos</h2>\n        <button class=\"btn btn-dark fw-bold px-4\" (click)=\"volverAlMenu()\">Ver Menú Público</button>\n      </div>\n\n      <div class=\"table-container\">\n        <div class=\"table-responsive\">\n          <table class=\"table table-hover align-middle\">\n            <thead>\n              <tr>\n                <th class=\"text-warning\">ID</th>\n                <th class=\"text-warning\">Nombre del Producto</th>\n                <th class=\"text-warning\">Descripción</th>\n                <th class=\"text-warning\">Categoría</th>\n                <th class=\"text-warning text-center\">Precio 1</th>\n                <th class=\"text-warning text-center\">Precio 2</th>\n                <th class=\"text-warning text-center\">Precio 3</th>\n                <th class=\"text-warning text-center\">Acciones</th>\n              </tr>\n            </thead>\n            <tbody>\n              @for (p of listaPizzas(); track p.id) {\n                <tr>\n                  <td class=\"text-muted fw-bold\">#{{ p.id }}</td>\n                  <td>\n                    <div class=\"fw-bold text-white h5 mb-0\">{{ p.nombre }}</div>\n                  </td>\n                  <td class=\"text-white\">\n                    {{ p.descripcion }}\n                  </td>\n                  <td class=\"text-white\">\n                    <span class=\"badge bg-secondary\">{{ p.categoria }}</span>\n                  </td>\n                  <td class=\"text-info text-center fw-bold\">\n                    <span *ngIf=\"p.precio_1\">${{ p.precio_1 | number:'1.0-0' }}</span>\n                  </td>\n                  <td class=\"text-success text-center fw-bold\">\n                    <span *ngIf=\"p.precio_2\">${{ p.precio_2 | number:'1.0-0' }}</span>\n                  </td>\n                  <td class=\"text-warning text-center fw-bold\">\n                    <span *ngIf=\"p.precio_3\">${{ p.precio_3 | number:'1.0-0' }}</span>\n                  </td>\n                  <td class=\"text-center\">\n                    <button class=\"btn btn-sm btn-outline-danger\" (click)=\"eliminarPizza(p.id)\">🗑️ Filtrar/Borrar</button>\n                  </td>\n                </tr>\n              }\n            </tbody>\n          </table>\n        </div>\n        \n        <!-- Formulario Agregar Pizza | Add Pizza Form -->\n        <div class=\"mt-4 pb-5\">\n          <button class=\"btn btn-warning fw-bold mb-3\" (click)=\"toggleFormulario()\" *ngIf=\"!mostrarFormulario\">➕ Agregar Producto</button>\n          \n          <div class=\"card p-3 border-warning bg-dark\" *ngIf=\"mostrarFormulario\" style=\"max-width: 800px; border-radius: 8px;\">\n            <h5 class=\"text-crema mb-3\">Registrar Nuevo Producto</h5>\n            <div class=\"row g-2 align-items-end\">\n              <div class=\"col-md-3\">\n                <label class=\"form-label text-white small mb-1\">Nombre</label>\n                <input class=\"form-control form-control-sm bg-dark text-white border-secondary\" placeholder=\"Ej: Hawaiana\" [(ngModel)]=\"nuevaPizza.nombre\">\n              </div>\n              <div class=\"col-md-6\">\n                <label class=\"form-label text-white small mb-1\">Descripción</label>\n                <input class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.descripcion\" placeholder=\"Ingredientes detallados\">\n              </div>\n              <div class=\"col-md-3\">\n                <label class=\"form-label text-white small mb-1\">Categoría</label>\n                <select class=\"form-select form-select-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.categoria\">\n                  <option *ngFor=\"let cat of categoriasPosibles\" [value]=\"cat\">{{cat}}</option>\n                </select>\n              </div>\n              \n              <!-- Precios dinámicos -->\n              <div class=\"col-md-3\" *ngIf=\"mostrarCampoPrecio(1)\">\n                <label class=\"form-label text-warning small mb-1\">{{ getEtiquetaPrecio(1) }}</label>\n                <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.precio_1\" placeholder=\"$\">\n              </div>\n              <div class=\"col-md-3\" *ngIf=\"mostrarCampoPrecio(2)\">\n                <label class=\"form-label text-warning small mb-1\">{{ getEtiquetaPrecio(2) }}</label>\n                <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.precio_2\" placeholder=\"$\">\n              </div>\n              <div class=\"col-md-3\" *ngIf=\"mostrarCampoPrecio(3)\">\n                <label class=\"form-label text-warning small mb-1\">{{ getEtiquetaPrecio(3) }}</label>\n                <input type=\"number\" class=\"form-control form-control-sm bg-dark text-white border-secondary\" [(ngModel)]=\"nuevaPizza.precio_3\" placeholder=\"$\">\n              </div>\n              \n              <div class=\"col-md-3 d-flex gap-2 ms-auto mt-3\">\n                <button class=\"btn btn-sm btn-success fw-bold w-100\" (click)=\"guardarPizza()\">Guardar</button>\n                <button class=\"btn btn-sm btn-outline-light w-100\" (click)=\"cancelarFormulario()\">Cancelar</button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n",
    "token_count_estimate": 802
}