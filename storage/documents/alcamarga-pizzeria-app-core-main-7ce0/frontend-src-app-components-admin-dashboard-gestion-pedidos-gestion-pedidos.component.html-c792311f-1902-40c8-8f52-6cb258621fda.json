    "pageContent": "<div class=\"gestion-container\">\n  <div class=\"header\">\n    <h2>Gestión de Pedidos</h2>\n    <p>Control de flujo y estados de venta</p>\n  </div>\n\n  <div *ngIf=\"cargando\" class=\"loading\">\n    <div class=\"spinner\"></div>\n  </div>\n\n  <div *ngIf=\"!cargando\" class=\"table-wrapper\">\n    <table class=\"admin-table\">\n      <thead>\n        <tr>\n          <th>ID</th>\n          <th>Fecha</th>\n          <th>Cliente ID</th>\n          <th>Total</th>\n          <th>Artículos</th>\n          <th>Estado</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr *ngFor=\"let p of pedidos\">\n          <td>#{{ p.id }}</td>\n          <td>{{ p.fecha_hora }}</td>\n          <td>User #{{ p.usuario_id }}</td>\n          <td class=\"price\">{{ p.total | currency:'USD':'symbol':'1.0-0' }}</td>\n          <td>\n            <div class=\"articulos-cell\">\n              <span *ngFor=\"let a of p.articulos\">{{ a.cantidad }}x {{ a.nombre }}</span>\n            </div>\n          </td>\n          <td>\n            <select \n              [(ngModel)]=\"p.estado\" \n              (change)=\"cambiarEstado(p.id, p.estado)\"\n              [class]=\"'status-select ' + p.estado.toLowerCase()\">\n              <option *ngFor=\"let st of estadosDisponibles\" [value]=\"st\">{{ st }}</option>\n            </select>\n          </td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <!-- Toast Notification -->\n  <div class=\"toast-notification\" [class.show]=\"mostrarToast()\">\n    {{ mensajeToast() }}\n  </div>\n</div>\n",
