    "pageContent": "<div class=\"dashboard-container\">\n  <h1>Panel de Administrador</h1>\n  \n  <div class=\"row g-4 mb-4\" *ngIf=\"usuario?.rol === 'admin'\">\n    <div class=\"col-md-4\">\n      <div class=\"stat-card p-3 d-flex align-items-center\">\n        <div class=\"icon-box bg-success bg-opacity-25 text-success me-3\">💰</div>\n        <div>\n          <div class=\"text-muted small\">Ventas del Día</div>\n          <div class=\"h4 fw-bold mb-0\">${{ ventasDelDia | number }}</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"col-md-4\">\n      <div class=\"stat-card p-3 d-flex align-items-center\">\n        <div class=\"icon-box bg-warning bg-opacity-25 text-warning me-3\">📦</div>\n        <div>\n          <div class=\"text-muted small\">Pedidos Pendientes</div>\n          <div class=\"h4 fw-bold mb-0\">{{ pedidosPendientes }}</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"col-md-4\">\n      <div class=\"stat-card p-3 d-flex align-items-center\">\n        <div class=\"icon-box bg-info bg-opacity-25 text-info me-3\">🍕</div>\n        <div>\n          <div class=\"text-muted small\">Pizzas en Inventario</div>\n          <div class=\"h4 fw-bold mb-0\">{{ inventarioPizzas }}</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"tabs-container mt-4 mb-3 p-3\" style=\"background: rgba(0,0,0,0.6); border-radius: 10px; border: 1px solid rgba(212,175,55,0.3);\">\n    <ul class=\"nav nav-tabs border-0\">\n      <li class=\"nav-item\" *ngIf=\"usuario?.rol === 'admin'\">\n        <a class=\"nav-link fw-bold\" \n           [ngClass]=\"pestanaActiva === 'menu' ? 'text-dark bg-warning border-warning' : 'text-warning'\" \n           (click)=\"cambiarPestana('menu')\" \n           style=\"cursor: pointer; font-size: 1.1rem; border-radius: 8px 8px 0 0;\">\n           🍕 Gestión de Menú\n        </a>\n      </li>\n      <li class=\"nav-item ms-2\" *ngIf=\"usuario?.rol === 'admin'\">\n        <a class=\"nav-link fw-bold\" \n           [ngClass]=\"pestanaActiva === 'insumos' ? 'text-dark bg-warning border-warning' : 'text-warning'\" \n           (click)=\"cambiarPestana('insumos')\" \n           style=\"cursor: pointer; font-size: 1.1rem; border-radius: 8px 8px 0 0;\">\n           🧀 Inventario de Insumos\n        </a>\n      </li>\n       <li class=\"nav-item ms-2\">\n        <a class=\"nav-link fw-bold\" \n           [ngClass]=\"pestanaActiva === 'pedidos' ? 'text-dark bg-warning border-warning' : 'text-warning'\" \n           (click)=\"cambiarPestana('pedidos')\" \n           style=\"cursor: pointer; font-size: 1.1rem; border-radius: 8px 8px 0 0;\">\n           📋 Gestión de Pedidos\n        </a>\n      </li>\n      <li class=\"nav-item ms-2\" *ngIf=\"usuario?.rol === 'admin'\">\n        <a class=\"nav-link fw-bold\" \n           [ngClass]=\"pestanaActiva === 'recetas' ? 'text-dark bg-warning border-warning' : 'text-warning'\" \n           (click)=\"cambiarPestana('recetas')\" \n           style=\"cursor: pointer; font-size: 1.1rem; border-radius: 8px 8px 0 0;\">\n           🥣 Configuración de Recetas\n        </a>\n      </li>\n      <li class=\"nav-item ms-2\" *ngIf=\"usuario?.rol === 'admin'\">\n        <a class=\"nav-link fw-bold\" \n           [ngClass]=\"pestanaActiva === 'personal' ? 'text-dark bg-warning border-warning' : 'text-warning'\" \n           (click)=\"cambiarPestana('personal')\" \n           style=\"cursor: pointer; font-size: 1.1rem; border-radius: 8px 8px 0 0;\">\n           👥 Gestión de Personal\n        </a>\n      </li>\n    </ul>\n  </div>\n\n  <div class=\"tab-content\">\n    <div *ngIf=\"pestanaActiva === 'menu'\">\n      <!-- Componente para las Pizzas y 3 precios | Pizza catalog component -->\n      <app-dashboard></app-dashboard>\n    </div>\n    \n    <div *ngIf=\"pestanaActiva === 'insumos'\">\n      <!-- Componente para harina, queso, etc. | Supplies inventory component -->\n      <app-inventario></app-inventario>\n    </div>\n\n    <div *ngIf=\"pestanaActiva === 'pedidos'\">\n      <!-- Componente para gestionar pedidos y estados -->\n      <app-gestion-pedidos></app-gestion-pedidos>\n    </div>\n\n    <div *ngIf=\"pestanaActiva === 'recetas' && usuario?.rol === 'admin'\">\n      <!-- Componente para configurar recetas -->\n      <app-configuracion-recetas></app-configuracion-recetas>\n    </div>\n\n    <div *ngIf=\"pestanaActiva === 'personal' && usuario?.rol === 'admin'\">\n      <!-- Componente para gestionar personal -->\n      <app-gestion-personal></app-gestion-personal>\n    </div>\n  </div>\n</div>\n",
