    "pageContent": "<div class=\"gestion-container p-4\">\n  <div class=\"d-flex justify-content-between align-items-center mb-4\">\n    <h2 class=\"text-gold\"><i class=\"fas fa-users-cog me-2\"></i>Gestión de Personal</h2>\n    <button class=\"btn btn-gold\" (click)=\"abrirModalNuevo()\">\n      <i class=\"fas fa-user-plus me-2\"></i>Nuevo Empleado\n    </button>\n  </div>\n\n  <!-- Tabla de Personal -->\n  <div class=\"card bg-dark-glass border-gold\">\n    <div class=\"table-responsive\">\n      <table class=\"table table-dark table-hover mb-0\">\n        <thead class=\"text-gold border-gold\">\n          <tr>\n            <th>ID</th>\n            <th>Nombre</th>\n            <th>Email</th>\n            <th>Rol</th>\n            <th>Fecha Registro</th>\n            <th>Acciones</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr *ngFor=\"let u of personal()\">\n            <td>{{ u.id }}</td>\n            <td class=\"fw-bold\">{{ u.nombre }}</td>\n            <td>{{ u.email }}</td>\n            <td>\n              <span class=\"badge\" [ngClass]=\"{\n                'bg-danger': u.rol === 'admin',\n                'bg-info text-dark': u.rol === 'cocinero',\n                'bg-warning text-dark': u.rol === 'domiciliario'\n              }\">{{ u.rol | uppercase }}</span>\n            </td>\n            <td>{{ u.fecha_registro | date:'short' }}</td>\n            <td>\n              <div class=\"d-flex gap-2\">\n                <button class=\"btn btn-sm btn-outline-warning me-2\" (click)=\"prepararEdicion(u)\">\n                  <i class=\"fas fa-edit me-1\"></i> Editar\n                </button>\n                <button class=\"btn btn-sm btn-outline-danger\" (click)=\"eliminarUsuario(u.id!)\">\n                  <i class=\"fas fa-trash me-1\"></i> Eliminar\n                </button>\n              </div>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n\n  <!-- Modal / Formulario Flotante -->\n  <div class=\"modal-overlay\" *ngIf=\"mostrarFormulario\" (click)=\"mostrarFormulario = false\">\n    <div class=\"modal-content bg-dark border-gold p-4\" (click)=\"$event.stopPropagation()\">\n      <h3 class=\"text-gold mb-4\">{{ editandoId ? 'Editar' : 'Registrar' }} Empleado</h3>\n      \n      <div class=\"mb-3\">\n        <label class=\"form-label text-light\">Nombre Completo</label>\n        <input type=\"text\" class=\"form-control bg-dark text-light border-gold\" \n               [(ngModel)]=\"nuevoUsuario.nombre\" placeholder=\"Ej: Juan Pérez\">\n      </div>\n\n      <div class=\"mb-3\">\n        <label class=\"form-label text-light\">Correo Electrónico</label>\n        <input type=\"email\" class=\"form-control bg-dark text-light border-gold\" \n               [(ngModel)]=\"nuevoUsuario.email\" placeholder=\"ejemplo@pizzeria.com\">\n      </div>\n\n      <div class=\"mb-3\">\n        <label class=\"form-label text-light\">Contraseña Inicial</label>\n        <input type=\"password\" class=\"form-control bg-dark text-light border-gold\" \n               [(ngModel)]=\"nuevoUsuario.password\" placeholder=\"Mínimo 6 caracteres\">\n      </div>\n\n      <div class=\"mb-4\">\n        <label class=\"form-label text-light\">Asignar Rol</label>\n        <select class=\"form-select bg-dark text-light border-gold\" [(ngModel)]=\"nuevoUsuario.rol\">\n          <option *ngFor=\"let rol of rolesDisponibles\" [value]=\"rol\">{{ rol | uppercase }}</option>\n        </select>\n      </div>\n\n      <div class=\"d-flex gap-2\">\n        <button class=\"btn btn-outline-light w-100\" (click)=\"mostrarFormulario = false\">Cancelar</button>\n        <button class=\"btn btn-gold w-100\" (click)=\"registrarPersonal()\">Guardar Registro</button>\n      </div>\n    </div>\n  </div>\n</div>\n",
    "token_count_estimate": 954
}