 (Debian GLIBC 2.22-11) 2.22\n#\n# This is unfortunate, because it means that the linehaul data on libc\n# versions that was generated by pip 8.1.2 and earlier is useless and\n# misleading. Solution: instead of using platform, use our code that actually\n# works.\ndef libc_ver() -> Tuple[str, str]:\n    \"\"\"Try to determine the glibc version"}},{"id":"9d6d8812-43d2-4424-ae32-529856dcd5d3","values":[-0.02645234763622284,0.02162603847682476,-0.0008756313472986221,-0.02308638207614422,0.06565256416797638,-0.04794172942638397,-0.014543556608259678,-0.022069333121180534,0.0199551060795784,-0.06928198784589767,0.006397757679224014,-0.005485885310918093,-0.041017815470695496,-0.10286311060190201,0.008090920746326447,0.03670976683497429,0.01753283105790615,0.028625382110476494,-0.006075382232666016,-0.037094276398420334,-0.03031308948993683,0.0902591273188591,0.053289055824279785,0.07495316118001938,0.012089980766177177,-0.08554834872484207,-0.06605269014835358,-0.02951784059405327,-0.027060801163315773,0.0837002694606781,0.02764822356402874,0.09777137637138367,-0.032209474593400955,-0.047721900045871735,0.1910923421382904,0.05486063286662102,0.00013583384861703962,-0.007751147262752056,0.013539127074182034,0.03507997840642929,-0.03945256024599075,-0.015115213580429554,-0.043532226234674454,0.008505010977387428,-0.08241527527570724,0.0754489153623581,0.004479178227484226,0.03274446725845337,0.03174855187535286,-0.015295946970582008,0.0023011600133031607,-0.02811545506119728,-0.1407294124364853,-0.021165909245610237,0.061150871217250824,0.031050341203808784,-0.11099695414304733,0.002339970553293824,-0.048171114176511765,0.04362162575125694,-0.08602198958396912,0.006008930038660765,-0.005616614129394293,-0.006998572964221239,0.006641630083322525,0.04504590854048729,0.03237828239798546,-0.07488078624010086,0.0701575055718422,0.02806134708225727,-0.0007960216025821865,-0.01310393214225769,-0.0425143763422966,-0.018197203055024147,-0.06844756007194519,0.05182875320315361,0.042