497880220413,-0.029254097491502762,0.01968444511294365,0.01830720342695713,-0.026317710056900978],"metadata":{"id":"56b4980c-19a5-47d4-aac0-f706860bca55","url":"github://.venv/lib/python3.12/site-packages/greenlet/platform/switch_sh_gcc.h","title":".venv/lib/python3.12/site-packages/greenlet/platform/switch_sh_gcc.h","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/platform/switch_sh_gcc.h","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:167f98d625b9128483eb2390a9fbec44","published":"4/26/2026, 11:03:34 PM","wordCount":226,"token_count_estimate":299,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/platform/switch_sh_gcc.h\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\n#define STACK_REFPLUS 1\n\n#ifdef SLP_EVAL\n#define STACK_MAGIC 0\n#define REGS_TO_SAVE \"r8\", \"r9\", \"r10\", \"r11\", \"r13\", \\\n                     \"fr12\", \"fr13\", \"fr14\", \"fr15\"\n\n// r12 Global context pointer, GP\n// r14 Frame pointer, FP\n// r15 Stack pointer, SP\n\nstatic int\nslp_switch(void)\n{\n    int err;\n    void* fp;\n    int *stackref, stsizediff;\n    __asm__ volatile(\"\" : : : REGS_TO_SAVE);\n    __asm__ volatile(\"mov.l r14, %0\" : \"=m\"(fp) : :);\n    __asm__(\"mov r15, %0\" : \"=r\"(stackref));\n    {\n        SLP_SAVE_STATE(stackref, stsizediff);\n        __asm__ volatile(\n            \"add %0, r15\\n\"\n            \"add %0, r14\\n\"\n            : /* no outputs */\n            : \"r\"(stsizediff));\n        SLP_RESTORE_STATE();\n        __asm__ volatile(\"mov r0, %0\" : \"=r\"(err) : :);\n    }\n    __asm__ volatile(\"mov.l %0, r14\" : : \"m\"(fp) :);\n    __asm__ volatile(\"\" : : : REGS_TO_SAVE);\n    return err;\n}\n\n#endif"}}]]