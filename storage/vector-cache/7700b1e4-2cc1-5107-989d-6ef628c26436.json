site-packages/sqlalchemy/engine/_py_row.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:ae253353ca2f44cb64a7ed44f5b75b7e","published":"4/26/2026, 11:03:36 PM","wordCount":900,"token_count_estimate":893,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/sqlalchemy/engine/_py_row.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\ndef __getattr__(self, name: str) -> Any:\n        try:\n            return self._data[self._key_to_index[name]]\n        except KeyError:\n            pass\n        self._parent._key_not_found(name, True)\n\n    def _to_tuple_instance(self) -> Tuple[Any, ...]:\n        return self._data\n\n\n# This reconstructor is necessary so that pickles with the Cy extension or\n# without use the same Binary format.\ndef rowproxy_reconstructor(\n    cls: Type[BaseRow], state: Dict[str, Any]\n) -> BaseRow:\n    obj = cls.__new__(cls)\n    obj.__setstate__(state)\n    return obj\n\n\ndef tuplegetter(*indexes: int) -> _TupleGetterType:\n    if len(indexes) != 1:\n        for i in range(1, len(indexes)):\n            if indexes[i - 1] != indexes[i] - 1:\n                return operator.itemgetter(*indexes)\n    # slice form is faster but returns a list if input is list\n    return operator.itemgetter(slice(indexes[0], indexes[-1] + 1))"}}]]