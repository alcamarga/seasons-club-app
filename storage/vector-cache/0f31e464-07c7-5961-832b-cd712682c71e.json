923,0.03966299816966057,-0.05514940991997719,-0.0011674158740788698,0.030721990391612053,-0.02115563489496708],"metadata":{"id":"773dfb0e-bc70-4d73-aafd-b177cd508e49","url":"github://.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py","title":".venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:992baf29f0536f5a177b6c5bee785468","published":"4/26/2026, 11:03:34 PM","wordCount":126,"token_count_estimate":233,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\n\"\"\"\nUses a trace function to switch greenlets at unexpected times.\n\nIn the trace function, we switch from the current greenlet to another\ngreenlet, which switches\n\"\"\"\nimport greenlet\n\ng1 = None\ng2 = None\n\nswitch_to_g2 = False\n\ndef tracefunc(*args):\n    print('TRACE', *args)\n    global switch_to_g2\n    if switch_to_g2:\n        switch_to_g2 = False\n        g2.switch()\n    print('\\tLEAVE TRACE', *args)\n\ndef g1_run():\n    print('In g1_run')\n    global switch_to_g2\n    switch_to_g2 = True\n    greenlet.getcurrent().parent.switch()\n    print('Return to g1_run')\n    print('Falling off end of g1_run')\n\ndef g2_run():\n    g1.switch()\n    print('Falling off end of g2')\n\ngreenlet.settrace(tracefunc)\n\ng1 = greenlet.greenlet(g1_run)\ng2 = greenlet.greenlet(g2_run)\n\ng1.switch()\nprint('Falling off end of main')\ng2.switch()"}}]]