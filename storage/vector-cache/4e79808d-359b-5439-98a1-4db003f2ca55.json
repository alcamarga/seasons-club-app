n        self.last = self.match\n        m = self._re_cache[pattern].match(self.data, self.pos)\n        if m is None:\n            return False\n        self.start_pos = m.start()\n        self.pos = m.end()\n        self.match = m.group()\n        return True\n\n    def get_char(self):\n        \"\"\"Scan exactly one char.\"\"\"\n        self.scan('.')"}},{"id":"673c64b4-5b75-4901-a7b7-2c7a98af5832","values":[-0.045877162367105484,0.06025686860084534,-0.10409624874591827,0.0012294339248910546,-0.02362087555229664,-0.0831286683678627,0.04249522462487221,0.0008457787334918976,-0.051482122391462326,-0.04074102267622948,0.06203858554363251,0.01301661878824234,0.06836862862110138,0.01856718584895134,-0.056152213364839554,0.010772203095257282,-0.10058185458183289,0.05121409893035889,0.0640747994184494,-0.05039301514625549,0.0006814100197516382,0.07650864869356155,0.059356994926929474,0.041159383952617645,-0.026909301057457924,-0.05284600332379341,-0.07879322022199631,0.030256958678364754,-0.0178958922624588,-0.03499653562903404,0.09226491302251816,0.04716195538640022,0.04977065324783325,0.011492195539176464,0.1267009973526001,0.06346268951892853,0.00547020835801959,0.013904966413974762,-0.032886795699596405,0.04476926103234291,0.05399463698267937,-0.0459013469517231,-0.0445665642619133,-0.021571073681116104,-0.052704278379678726,-0.010486742481589317,0.03214589133858681,-0.05508967861533165,-0.01157060544937849,-0.028647296130657196,-0.042847663164138794,-0.02611270174384117,-0.0904640480875969,-0.005292163696140051,0.002771122381091118,-0.012652197852730751,0.039533548057079315,0.044654302299022675,-0.06069865822792053,-0.03706427291035652,-0.03563657030463219,0.038362011313438416,-0.004043536260724068,-0.0012110344832763076,-0.06661603599786758,0.01764901727437973,0.04453970491886139,0.006874441634863615,0.08038228750228882,-0.008130721747875214,-0.011795672588050365,-0.019800540059804916,-0.0008675535791553557,-0.02716890536248684,0.05368274822831154,-0.0353215858340