3363514,-0.03081187792122364,0.04655178263783455,0.06927742063999176,0.04588109999895096,-0.012507060542702675],"metadata":{"id":"f91bef90-ff64-448a-a669-ab7d80c9d455","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/hooks.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/hooks.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/hooks.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:1289552dd1181e1b149b6b7c7580c155","published":"4/26/2026, 11:03:36 PM","wordCount":164,"token_count_estimate":170,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/hooks.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\n\"\"\"\nrequests.hooks\n~~~~~~~~~~~~~~\n\nThis module provides the capabilities for the Requests hooks system.\n\nAvailable hooks:\n\n``response``:\n    The response generated from a Request.\n\"\"\"\nHOOKS = [\"response\"]\n\n\ndef default_hooks():\n    return {event: [] for event in HOOKS}\n\n\n# TODO: response is the only one\n\n\ndef dispatch_hook(key, hooks, hook_data, **kwargs):\n    \"\"\"Dispatches a hook dictionary on a given piece of data.\"\"\"\n    hooks = hooks or {}\n    hooks = hooks.get(key)\n    if hooks:\n        if hasattr(hooks, \"__call__\"):\n            hooks = [hooks]\n        for hook in hooks:\n            _hook_data = hook(hook_data, **kwargs)\n            if _hook_data is not None:\n                hook_data = _hook_data\n    return hook_data"}}]]