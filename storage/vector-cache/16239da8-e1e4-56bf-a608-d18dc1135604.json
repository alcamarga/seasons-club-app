s/greenlet/tests/test_throw.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:9f3ec662640067ef08b3cf8a3217faae","published":"4/26/2026, 11:03:35 PM","wordCount":1217,"token_count_estimate":775,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ng1 = greenlet(f1)\n        g2 = greenlet(f2, parent=g1)\n        with self.assertRaises(IndexError):\n            g2.throw(IndexError)\n        self.assertTrue(g2.dead)\n        self.assertTrue(g1.dead)\n\n        g1 = greenlet(f1)\n        g2 = greenlet(f2, parent=g1)\n        res = g1.switch()\n        self.assertEqual(res, \"f1 ready to catch\")\n        res = g2.throw(IndexError)\n        self.assertEqual(res, \"caught\")\n        self.assertTrue(g2.dead)\n        self.assertTrue(g1.dead)\n\n        g1 = greenlet(f1)\n        g2 = greenlet(f2, parent=g1)\n        res = g1.switch()\n        self.assertEqual(res, \"f1 ready to catch\")\n        res = g2.switch()\n        self.assertEqual(res, \"from f2\")\n        res = g2.throw(IndexError)\n        self.assertEqual(res, \"caught\")\n        self.assertTrue(g2.dead)\n        self.assertTrue(g1.dead)"}},{"id":"26e506a3-a2fa-410f-8462-e7b874903b92","values":[-0.009274669922888279,0.010746447369456291,-0.0212960634380579,0.03418580815196037,0.09107492119073868,-0.05754401162266731,0.017302503809332848,0.033393993973731995,-0.0033015855588018894,-0.0372629351913929,0.04833155497908592,-0.07902567833662033,0.028290726244449615,-0.03235722333192825,0.021449534222483635,-0.0386417880654335,-0.024596286937594414,0.044879425317049026,-0.018812237307429314,-0.00892759207636118,0.023817194625735283,0.06347579509019852,0.044365640729665756,0.08391837775707245,-0.07752241939306259,-0.093234024