:{"id":"fce069b7-bf72-4096-94c9-30a751f70b85","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:9f3ec662640067ef08b3cf8a3217faae","published":"4/26/2026, 11:03:35 PM","wordCount":1217,"token_count_estimate":775,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ng = greenlet(f)\n        res = g.switch()\n        self.assertEqual(res, \"ok\")\n        res = g.throw(RuntimeError, \"ciao\")\n        self.assertEqual(res, \"ok\")\n\n    def test_kill(self):\n        def f():\n            switch(\"ok\")\n            switch(\"fail\")\n        g = greenlet(f)\n        res = g.switch()\n        self.assertEqual(res, \"ok\")\n        res = g.throw()\n        self.assertTrue(isinstance(res, greenlet.GreenletExit))\n        self.assertTrue(g.dead)\n        res = g.throw()    # immediately eaten by the already-dead greenlet\n        self.assertTrue(isinstance(res, greenlet.GreenletExit))\n\n    def test_throw_goes_to_original_parent(self):\n        main = greenlet.getcurrent()\n\n        def f1():\n            try:\n                main.switch(\"f1 ready to catch\")\n            except IndexError:\n                return \"caught\"\n            return \"normal exit\"\n\n        def f2():\n            main.switch(\"from f2\")"}},{"id":"def5ab64-dcde-4db2-ac12-56c372771638","values":[-0.06823565065860748,-0.0024613263085484505,0.009006551466882229,-0.00878133438527584,0.10157696157693863,-0.04689393192529678,-0.007040239404886961,0.026558399200439453,0.00013014209980610758,0.005148292053490877,0.08942116051912308,-0.068102