0.012989331968128681,-0.005072394851595163,0.11547663807868958,0.0017750108381733298,0.10216667503118515,0.07319929450750351],"metadata":{"id":"2dffe1b0-c303-4eb2-99e7-35fdb2511963","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_fileno.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_fileno.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_fileno.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:72146c010c176b6c11b39055a0954654","published":"4/26/2026, 11:03:36 PM","wordCount":204,"token_count_estimate":181,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_fileno.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\nfrom __future__ import annotations\n\nfrom typing import IO, Callable\n\n\ndef get_fileno(file_like: IO[str]) -> int | None:\n    \"\"\"Get fileno() from a file, accounting for poorly implemented file-like objects.\n\n    Args:\n        file_like (IO): A file-like object.\n\n    Returns:\n        int | None: The result of fileno if available, or None if operation failed.\n    \"\"\"\n    fileno: Callable[[], int] | None = getattr(file_like, \"fileno\", None)\n    if fileno is not None:\n        try:\n            return fileno()\n        except Exception:\n            # `fileno` is documented as potentially raising a OSError\n            # Alas, from the issues, there are so many poorly implemented file-like objects,\n            # that `fileno()` can raise just about anything.\n            return None\n    return None"}}]]