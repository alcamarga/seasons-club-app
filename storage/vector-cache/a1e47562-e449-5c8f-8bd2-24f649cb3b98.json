63402312994,0.07182783633470535,0.03408673778176308,0.07979533076286316,0.06527956575155258],"metadata":{"id":"7375ecc3-fb61-4ac9-9f94-b2dae150e5d7","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:0103e72c89501a9ce5b284f0046c25c5","published":"4/26/2026, 11:03:36 PM","wordCount":83,"token_count_estimate":89,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\nfrom typing import List, TypeVar\n\nT = TypeVar(\"T\")\n\n\nclass Stack(List[T]):\n    \"\"\"A small shim over builtin list.\"\"\"\n\n    @property\n    def top(self) -> T:\n        \"\"\"Get top of stack.\"\"\"\n        return self[-1]\n\n    def push(self, item: T) -> None:\n        \"\"\"Push an item on to the stack (append in stack nomenclature).\"\"\"\n        self.append(item)"}}]]