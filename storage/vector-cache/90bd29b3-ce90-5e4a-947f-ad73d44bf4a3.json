earing_run_switches.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_clearing_run_switches.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_clearing_run_switches.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:d3a352ecc90be5833126b475733d1ae5","published":"4/26/2026, 11:03:35 PM","wordCount":201,"token_count_estimate":306,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_clearing_run_switches.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ng = G(RunCallable())\n# Try to start G. It will get to the point where it deletes\n# its run callable C++ variable in inner_bootstrap. That triggers\n# the __del__ method, which switches back to main before g\n# actually even starts running.\nx = g.switch()\nresults.append(('main: g.switch()', x))\n# In the C++ code, this results in g->g_switch() appearing to return, even though\n# it has yet to run.\nprint('In main with', x, flush=True)\ng.switch()\nprint('RESULTS', results)"}}]]