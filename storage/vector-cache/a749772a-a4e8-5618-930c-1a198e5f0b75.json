1,-0.022076673805713654,-0.020709702745079994,0.002279337728396058,0.07898730039596558,0.020016107708215714],"metadata":{"id":"390048ab-7465-4ab7-bad5-a57045dbb59a","url":"github://.venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp","title":".venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:33d840f75e276596acd2b0d754b0a498","published":"4/26/2026, 11:03:34 PM","wordCount":136,"token_count_estimate":193,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\n#ifndef GREENLET_THREAD_SUPPORT_HPP\n#define GREENLET_THREAD_SUPPORT_HPP\n\n/**\n * Defines various utility functions to help greenlet integrate well\n * with threads. This used to be needed when we supported Python\n * 2.7 on Windows, which used a very old compiler. We wrote an\n * alternative implementation using Python APIs and POSIX or Windows\n * APIs, but that's no longer needed. So this file is a shadow of its\n * former self --- but may be needed in the future.\n */\n\n#include <stdexcept>\n#include <thread>\n#include <mutex>\n\n#include \"greenlet_compiler_compat.hpp\"\n\nnamespace greenlet {\n    typedef std::mutex Mutex;\n    typedef std::lock_guard<Mutex> LockGuard;\n    class LockInitError : public std::runtime_error\n    {\n    public:\n        LockInitError(const char* what) : std::runtime_error(what)\n        {};\n    };\n};\n\n\n#endif /* GREENLET_THREAD_SUPPORT_HPP */"}}]]