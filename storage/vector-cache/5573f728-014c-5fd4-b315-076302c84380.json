995392,0.07711222767829895,0.01660609245300293,0.08155073970556259,0.06811989098787308],"metadata":{"id":"a92e21e7-c5d2-47f8-a2e8-bdd7c431f375","url":"github://.venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:76bfc383ff93575048560255895aaf8e","published":"4/26/2026, 11:03:35 PM","wordCount":83,"token_count_estimate":89,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/rich/_stack.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nfrom typing import List, TypeVar\n\nT = TypeVar(\"T\")\n\n\nclass Stack(List[T]):\n    \"\"\"A small shim over builtin list.\"\"\"\n\n    @property\n    def top(self) -> T:\n        \"\"\"Get top of stack.\"\"\"\n        return self[-1]\n\n    def push(self, item: T) -> None:\n        \"\"\"Push an item on to the stack (append in stack nomenclature).\"\"\"\n        self.append(item)"}}]]