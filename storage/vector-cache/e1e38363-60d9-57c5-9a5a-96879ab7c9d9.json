82843,0.08261460810899734,0.007752697449177504,0.025127097964286804,0.034733571112155914],"metadata":{"id":"8742fd2c-e075-4e89-a453-d0cc9061a5d9","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:85a051ae5fb532e8a6bd95ce1cf5364c","published":"4/26/2026, 11:03:35 PM","wordCount":260,"token_count_estimate":197,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nimport gc\nimport weakref\n\n\nimport greenlet\nfrom . import TestCase\n\nclass WeakRefTests(TestCase):\n    def test_dead_weakref(self):\n        def _dead_greenlet():\n            g = greenlet.greenlet(lambda: None)\n            g.switch()\n            return g\n        o = weakref.ref(_dead_greenlet())\n        gc.collect()\n        self.assertEqual(o(), None)\n\n    def test_inactive_weakref(self):\n        o = weakref.ref(greenlet.greenlet())\n        gc.collect()\n        self.assertEqual(o(), None)\n\n    def test_dealloc_weakref(self):\n        seen = []\n        def worker():\n            try:\n                greenlet.getcurrent().parent.switch()\n            finally:\n                seen.append(g())\n        g = greenlet.greenlet(worker)\n        g.switch()\n        g2 = greenlet.greenlet(lambda: None, g)\n        g = weakref.ref(g2)\n        g2 = None\n        self.assertEqual(seen, [None])"}}]]