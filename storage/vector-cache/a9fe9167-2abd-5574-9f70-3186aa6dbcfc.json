032522063702344894,-0.054949790239334106,0.06051613390445709,-0.056170348078012466,0.07769795507192612,0.032552722841501236],"metadata":{"id":"25b41b35-022c-4c2c-a9d3-f13a6de2c6b4","url":"github://.venv/lib/python3.12/site-packages/werkzeug/datastructures/etag.py","title":".venv/lib/python3.12/site-packages/werkzeug/datastructures/etag.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/werkzeug/datastructures/etag.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:7a3a242a933ad4b17e92d48d130ad786","published":"4/26/2026, 11:03:35 PM","wordCount":792,"token_count_estimate":710,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/werkzeug/datastructures/etag.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nfrom __future__ import annotations\n\nfrom collections.abc import Collection\n\n\nclass ETags(Collection):\n    \"\"\"A set that can be used to check if one etag is present in a collection\n    of etags.\n    \"\"\"\n\n    def __init__(self, strong_etags=None, weak_etags=None, star_tag=False):\n        if not star_tag and strong_etags:\n            self._strong = frozenset(strong_etags)\n        else:\n            self._strong = frozenset()\n\n        self._weak = frozenset(weak_etags or ())\n        self.star_tag = star_tag\n\n    def as_set(self, include_weak=False):\n        \"\"\"Convert the `ETags` object into a python set.  Per default all the\n        weak etags are not part of this set.\"\"\"\n        rv = set(self._strong)\n        if include_weak:\n            rv.update(self._weak)\n        return rv\n\n    def is_weak(self, etag):\n        \"\"\"Check if an etag is weak.\"\"\"\n        return etag in self._weak\n\n    def is_strong(self, etag):\n        \"\"\"Check if an etag is strong.\"\"\"\n        return etag in self._strong"}},{"id":"71bbef19-aa95-43da-a6b9-26a525103cb5","values":[-0.0324835479259491,0.03878021240234375,0.0