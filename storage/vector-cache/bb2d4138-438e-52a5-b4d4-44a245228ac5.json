72394123673439,-0.003473948920145631,0.09282971173524857,0.028895890340209007],"metadata":{"id":"cc995e89-8f59-4495-86f7-0e9f4c5b43a9","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp","title":"backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:6a2bb95b9d06bc822183b7e60179c9bc","published":"4/26/2026, 11:03:35 PM","wordCount":136,"token_count_estimate":193,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_thread_support.hpp\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\n#ifndef GREENLET_THREAD_SUPPORT_HPP\n#define GREENLET_THREAD_SUPPORT_HPP\n\n/**\n * Defines various utility functions to help greenlet integrate well\n * with threads. This used to be needed when we supported Python\n * 2.7 on Windows, which used a very old compiler. We wrote an\n * alternative implementation using Python APIs and POSIX or Windows\n * APIs, but that's no longer needed. So this file is a shadow of its\n * former self --- but may be needed in the future.\n */\n\n#include <stdexcept>\n#include <thread>\n#include <mutex>\n\n#include \"greenlet_compiler_compat.hpp\"\n\nnamespace greenlet {\n    typedef std::mutex Mutex;\n    typedef std::lock_guard<Mutex> LockGuard;\n    class LockInitError : public std::runtime_error\n    {\n    public:\n        LockInitError(const char* what) : std::runtime_error(what)\n        {};\n    };\n};\n\n\n#endif /* GREENLET_THREAD_SUPPORT_HPP */"}}]]