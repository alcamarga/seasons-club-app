b/python3.12/site-packages/pip/_vendor/requests/structures.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/structures.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/structures.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:3f8668ee46fa251e7ea23b98a1da09ea","published":"4/26/2026, 11:03:36 PM","wordCount":604,"token_count_estimate":671,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/requests/structures.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\nFor example, ``headers['content-encoding']`` will return the\n    value of a ``'Content-Encoding'`` response header, regardless\n    of how the header name was originally stored.\n\n    If the constructor, ``.update``, or equality comparison\n    operations are given keys that have equal ``.lower()``s, the\n    behavior is undefined.\n    \"\"\"\n\n    def __init__(self, data=None, **kwargs):\n        self._store = OrderedDict()\n        if data is None:\n            data = {}\n        self.update(data, **kwargs)\n\n    def __setitem__(self, key, value):\n        # Use the lowercased key for lookups, but store the actual\n        # key alongside the value.\n        self._store[key.lower()] = (key, value)\n\n    def __getitem__(self, key):\n        return self._store[key.lower()][1]\n\n    def __delitem__(self, key):\n        del self._store[key.lower()]\n\n    def __iter__(self):\n        return (casedkey for casedkey, mappedvalue in self._store.values())"}},{"id":"44b6b2e5-6135-4e1e-824f-f54a82446363","values":[-0.050856851041316986,0.0651387944817543,-0.006333685014396906,-0.022311516106128693,-0.02043890953063965,-0.07823897153139114,0.03333301469683647,-0.002451955573633313,-0.016839561983942986,-0.035576723515987396,0.09978493303060532,-0.04361753538250923,0.0558370016515255,-0.0791221410036087,0.041