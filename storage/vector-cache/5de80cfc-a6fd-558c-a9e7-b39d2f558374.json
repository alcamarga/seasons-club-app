eenlet_allocator.hpp","title":"backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_allocator.hpp","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_allocator.hpp","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:5f187550c02a309327f25597e1dffbed","published":"4/26/2026, 11:03:35 PM","wordCount":568,"token_count_estimate":407,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/greenlet_allocator.hpp\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nT* allocate(size_t number_objects, const void* UNUSED(hint)=0)\n        {\n            void* p;\n            if (number_objects == 1) {\n#ifdef Py_GIL_DISABLED\n                p = PyMem_Malloc(sizeof(T) * number_objects);\n#else\n                p = PyObject_Malloc(sizeof(T));\n#endif\n            }\n            else {\n                p = PyMem_Malloc(sizeof(T) * number_objects);\n            }\n            return static_cast<T*>(p);\n        }\n\n        void deallocate(T* t, size_t n)\n        {\n            void* p = t;\n            if (n == 1) {\n#ifdef Py_GIL_DISABLED\n                PyMem_Free(p);\n#else\n                PyObject_Free(p);\n#endif\n            }\n            else {\n                PyMem_Free(p);\n            }\n        }\n        // This member is deprecated in C++17 and removed in C++20\n        template< class U >\n        struct rebind {\n            typedef PythonAllocator<U> other;\n        };\n\n    };\n\n}\n\n#endif"}}]]