ion/resultproxy.pyx","title":"backend/.venv/lib/python3.12/site-packages/sqlalchemy/cyextension/resultproxy.pyx","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/sqlalchemy/cyextension/resultproxy.pyx","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:d6cba4f571de0296c5259e6020987275","published":"4/26/2026, 11:03:36 PM","wordCount":622,"token_count_estimate":674,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/sqlalchemy/cyextension/resultproxy.pyx\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\ncdef tuple _apply_processors(proc, data):\n    res = []\n    for i in range(len(proc)):\n        p = proc[i]\n        if p is None:\n            res.append(data[i])\n        else:\n            res.append(p(data[i]))\n    return tuple(res)\n\n\ndef rowproxy_reconstructor(cls, state):\n    obj = cls.__new__(cls)\n    obj.__setstate__(state)\n    return obj\n\n\ncdef int is_contiguous(tuple indexes):\n    cdef int i\n    for i in range(1, len(indexes)):\n        if indexes[i-1] != indexes[i] -1:\n            return 0\n    return 1\n\n\ndef tuplegetter(*indexes):\n    if len(indexes) == 1 or is_contiguous(indexes) != 0:\n        # slice form is faster but returns a list if input is list\n        return operator.itemgetter(slice(indexes[0], indexes[-1] + 1))\n    else:\n        return operator.itemgetter(*indexes)"}}]]