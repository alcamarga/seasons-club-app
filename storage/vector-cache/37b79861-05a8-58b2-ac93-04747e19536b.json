te-packages/pip/_vendor/tenacity/nap.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:99fd0a2ae362d740fab08a1b78926cb9","published":"4/26/2026, 11:03:35 PM","wordCount":235,"token_count_estimate":322,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nclass sleep_using_event:\n    \"\"\"Sleep strategy that waits on an event to be set.\"\"\"\n\n    def __init__(self, event: \"threading.Event\") -> None:\n        self.event = event\n\n    def __call__(self, timeout: typing.Optional[float]) -> None:\n        # NOTE(harlowja): this may *not* actually wait for timeout\n        # seconds if the event is set (ie this may eject out early).\n        self.event.wait(timeout=timeout)"}}]]