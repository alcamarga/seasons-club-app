urce":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_loop.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:978d097d3b490020978dcdd3492b4dee","published":"4/26/2026, 11:03:35 PM","wordCount":274,"token_count_estimate":282,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/rich/_loop.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ndef loop_first_last(values: Iterable[T]) -> Iterable[Tuple[bool, bool, T]]:\n    \"\"\"Iterate and generate a tuple with a flag for first and last value.\"\"\"\n    iter_values = iter(values)\n    try:\n        previous_value = next(iter_values)\n    except StopIteration:\n        return\n    first = True\n    for value in iter_values:\n        yield first, False, previous_value\n        first = False\n        previous_value = value\n    yield first, True, previous_value"}}]]