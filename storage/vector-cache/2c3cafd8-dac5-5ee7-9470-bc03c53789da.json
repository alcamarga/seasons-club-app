494423657655716,0.10097407549619675,-0.0028379678260535,0.01671678014099598,0.013275719247758389],"metadata":{"id":"737dbf09-351a-4fb6-9be5-8a75019ca2b7","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:2fbbaed817ec9bfdc323fdc7239a4e25","published":"4/26/2026, 11:03:36 PM","wordCount":107,"token_count_estimate":95,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\nfrom typing import Optional\n\n\ndef pick_bool(*values: Optional[bool]) -> bool:\n    \"\"\"Pick the first non-none bool or return the last value.\n\n    Args:\n        *values (bool): Any number of boolean or None values.\n\n    Returns:\n        bool: First non-none boolean.\n    \"\"\"\n    assert values, \"1 or more values required\"\n    for value in values:\n        if value is not None:\n            return value\n    return bool(value)"}}]]