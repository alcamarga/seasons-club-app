"url":"github://.venv/lib/python3.12/site-packages/greenlet/platform/switch_x64_masm.asm","title":".venv/lib/python3.12/site-packages/greenlet/platform/switch_x64_masm.asm","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/platform/switch_x64_masm.asm","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:59d1623958c71dfc74607ccdead9d20a","published":"4/26/2026, 11:03:34 PM","wordCount":441,"token_count_estimate":624,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/platform/switch_x64_masm.asm\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\npushreg rbp\n    pushreg rbx\n    pushreg rdi\n    pushreg rsi\n\n    sub rsp, 10h ;allocate the singlefunction argument (must be multiple of 16)\n    .allocstack 10h\n.endprolog\n\n    lea rcx, [rsp+10h] ;load stack base that we are saving\n    call slp_save_state_asm ;pass stackpointer, return offset in eax\n    cmp rax, 1\n    je EXIT1\n    cmp rax, -1\n    je EXIT2\n    ;actual stack switch:\n    add rsp, rax\n    call slp_restore_state_asm\n    xor rax, rax ;return 0\n\nEXIT:\n\n    add rsp, 10h\n    popreg rsi\n    popreg rdi\n    popreg rbx\n    popreg rbp\n\n    popreg r12\n    popreg r13\n    popreg r14\n    popreg r15\n\n    popxmm xmm6\n    popxmm xmm7\n    popxmm xmm8\n    popxmm xmm9\n    popxmm xmm10\n    popxmm xmm11\n    popxmm xmm12\n    popxmm xmm13\n    popxmm xmm14\n    popxmm xmm15\n\n    add rsp, 8\n    ret\n\nEXIT1:\n    mov rax, 1\n    jmp EXIT\n\nEXIT2:\n    sar rax, 1\n    jmp EXIT\n\nslp_switch ENDP\n\nEND"}}]]