0.07773224264383316,0.0024454540107399225,0.030273597687482834,0.0380580797791481],"metadata":{"id":"37d93552-4df2-4a63-83e5-636cf5cfa821","url":"github://.venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py","title":".venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:4fe7dedb49bbf26510f42817894e4904","published":"4/26/2026, 11:03:34 PM","wordCount":260,"token_count_estimate":197,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/tests/test_weakref.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nimport gc\nimport weakref\n\n\nimport greenlet\nfrom . import TestCase\n\nclass WeakRefTests(TestCase):\n    def test_dead_weakref(self):\n        def _dead_greenlet():\n            g = greenlet.greenlet(lambda: None)\n            g.switch()\n            return g\n        o = weakref.ref(_dead_greenlet())\n        gc.collect()\n        self.assertEqual(o(), None)\n\n    def test_inactive_weakref(self):\n        o = weakref.ref(greenlet.greenlet())\n        gc.collect()\n        self.assertEqual(o(), None)\n\n    def test_dealloc_weakref(self):\n        seen = []\n        def worker():\n            try:\n                greenlet.getcurrent().parent.switch()\n            finally:\n                seen.append(g())\n        g = greenlet.greenlet(worker)\n        g.switch()\n        g2 = greenlet.greenlet(lambda: None, g)\n        g = weakref.ref(g2)\n        g2 = None\n        self.assertEqual(seen, [None])"}}]]