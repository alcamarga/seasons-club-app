4355417229235,-0.024184880778193474,0.08891253918409348,0.021510019898414612,-0.00163183209951967],"metadata":{"id":"752851f7-0831-4eb6-ad41-1a6b03d780ac","url":"github://.venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:261be7f106d0b1b895e970bb4b465e86","published":"4/26/2026, 11:03:35 PM","wordCount":65,"token_count_estimate":105,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\n\"\"\"\nTimer context manager, only used in debug.\n\n\"\"\"\n\nfrom time import time\n\nimport contextlib\nfrom typing import Generator\n\n\n@contextlib.contextmanager\ndef timer(subject: str = \"time\") -> Generator[None, None, None]:\n    \"\"\"print the elapsed time. (only used in debugging)\"\"\"\n    start = time()\n    yield\n    elapsed = time() - start\n    elapsed_ms = elapsed * 1000\n    print(f\"{subject} elapsed {elapsed_ms:.1f}ms\")"}}]]