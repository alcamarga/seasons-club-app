795105934,-0.0866275355219841,0.10664910823106766,0.002236610045656562,0.020154474303126335,0.014796166680753231],"metadata":{"id":"fbc48642-9c8e-4724-860a-30b0261cf3b3","url":"github://.venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:9483adec6ddba5748500fbaf01e8dd79","published":"4/26/2026, 11:03:35 PM","wordCount":107,"token_count_estimate":95,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/rich/_pick.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nfrom typing import Optional\n\n\ndef pick_bool(*values: Optional[bool]) -> bool:\n    \"\"\"Pick the first non-none bool or return the last value.\n\n    Args:\n        *values (bool): Any number of boolean or None values.\n\n    Returns:\n        bool: First non-none boolean.\n    \"\"\"\n    assert values, \"1 or more values required\"\n    for value in values:\n        if value is not None:\n            return value\n    return bool(value)"}}]]