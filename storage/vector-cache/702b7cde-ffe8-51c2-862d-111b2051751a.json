ocAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_internal/commands/check.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:b4fd9c019c81912cbbf809cc79122266","published":"4/26/2026, 11:03:34 PM","wordCount":523,"token_count_estimate":321,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_internal/commands/check.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nfor project_name in missing:\n            version = package_set[project_name].version\n            for dependency in missing[project_name]:\n                write_output(\n                    \"%s %s requires %s, which is not installed.\",\n                    project_name,\n                    version,\n                    dependency[0],\n                )\n\n        for project_name in conflicting:\n            version = package_set[project_name].version\n            for dep_name, dep_version, req in conflicting[project_name]:\n                write_output(\n                    \"%s %s has requirement %s, but you have %s %s.\",\n                    project_name,\n                    version,\n                    req,\n                    dep_name,\n                    dep_version,\n                )\n\n        if missing or conflicting or parsing_probs:\n            return ERROR\n        else:\n            write_output(\"No broken requirements found.\")\n            return SUCCESS"}}]]