08135739713907242,0.027499845251441002,0.08277850598096848,-0.017136499285697937],"metadata":{"id":"8bac012e-5838-45b0-99a5-5a4062022438","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:ee737d66a9cb6e2f0907f74d4ade2b72","published":"4/26/2026, 11:03:35 PM","wordCount":106,"token_count_estimate":102,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nimport greenlet\nfrom . import TestCase\n\n\nclass Test(TestCase):\n\n    def test_stack_saved(self):\n        main = greenlet.getcurrent()\n        self.assertEqual(main._stack_saved, 0)\n\n        def func():\n            main.switch(main._stack_saved)\n\n        g = greenlet.greenlet(func)\n        x = g.switch()\n        self.assertGreater(x, 0)\n        self.assertGreater(g._stack_saved, 0)\n        g.switch()\n        self.assertEqual(g._stack_saved, 0)"}}]]