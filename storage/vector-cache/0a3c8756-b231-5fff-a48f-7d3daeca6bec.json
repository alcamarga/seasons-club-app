.py","title":".venv/lib/python3.12/site-packages/gunicorn/workers/workertmp.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/gunicorn/workers/workertmp.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:b12126a86db6e2ade88ce485b41acb8c","published":"4/26/2026, 11:03:34 PM","wordCount":415,"token_count_estimate":408,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/gunicorn/workers/workertmp.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\n# unlink the file so we don't leak temporary files\n        try:\n            if not IS_CYGWIN:\n                util.unlink(name)\n            # In Python 3.8, open() emits RuntimeWarning if buffering=1 for binary mode.\n            # Because we never write to this file, pass 0 to switch buffering off.\n            self._tmp = os.fdopen(fd, 'w+b', 0)\n        except Exception:\n            os.close(fd)\n            raise\n\n        self.spinner = 0\n\n    def notify(self):\n        self.spinner = (self.spinner + 1) % 2\n        os.fchmod(self._tmp.fileno(), self.spinner)\n\n    def last_update(self):\n        return os.fstat(self._tmp.fileno()).st_ctime\n\n    def fileno(self):\n        return self._tmp.fileno()\n\n    def close(self):\n        return self._tmp.close()"}}]]