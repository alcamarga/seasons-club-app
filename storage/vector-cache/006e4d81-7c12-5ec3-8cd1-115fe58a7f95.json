58965602517128,0.014696357771754265,0.027759099379181862,0.08175680786371231,-0.018240246921777725],"metadata":{"id":"5eac1155-71f0-4384-a531-66c8a5723c3a","url":"github://.venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py","title":".venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:bcef1b79aefc6bbd0168483288e6736d","published":"4/26/2026, 11:03:34 PM","wordCount":106,"token_count_estimate":102,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/tests/test_stack_saved.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nimport greenlet\nfrom . import TestCase\n\n\nclass Test(TestCase):\n\n    def test_stack_saved(self):\n        main = greenlet.getcurrent()\n        self.assertEqual(main._stack_saved, 0)\n\n        def func():\n            main.switch(main._stack_saved)\n\n        g = greenlet.greenlet(func)\n        x = g.switch()\n        self.assertGreater(x, 0)\n        self.assertGreater(g._stack_saved, 0)\n        g.switch()\n        self.assertEqual(g._stack_saved, 0)"}}]]