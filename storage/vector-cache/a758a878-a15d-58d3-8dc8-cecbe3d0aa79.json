2446193695,0.06727489829063416,0.008671170100569725,0.08499874919652939,0.04509422555565834],"metadata":{"id":"151f91c1-c861-4f09-b93d-5ffd6853813b","url":"github://.venv/lib/python3.12/site-packages/pip/_internal/models/candidate.py","title":".venv/lib/python3.12/site-packages/pip/_internal/models/candidate.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_internal/models/candidate.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:959db8c4970c4f06000a74d69faebf6d","published":"4/26/2026, 11:03:34 PM","wordCount":198,"token_count_estimate":209,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_internal/models/candidate.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nfrom pip._vendor.packaging.version import parse as parse_version\n\nfrom pip._internal.models.link import Link\nfrom pip._internal.utils.models import KeyBasedCompareMixin\n\n\nclass InstallationCandidate(KeyBasedCompareMixin):\n    \"\"\"Represents a potential \"candidate\" for installation.\"\"\"\n\n    __slots__ = [\"name\", \"version\", \"link\"]\n\n    def __init__(self, name: str, version: str, link: Link) -> None:\n        self.name = name\n        self.version = parse_version(version)\n        self.link = link\n\n        super().__init__(\n            key=(self.name, self.version, self.link),\n            defining_class=InstallationCandidate,\n        )\n\n    def __repr__(self) -> str:\n        return \"<InstallationCandidate({!r}, {!r}, {!r})>\".format(\n            self.name,\n            self.version,\n            self.link,\n        )\n\n    def __str__(self) -> str:\n        return f\"{self.name!r} candidate (version {self.version} at {self.link})\""}}]]