f3-86c2-79fe51a8725c","url":"github://backend/.venv/lib/python3.12/site-packages/sqlalchemy/testing/plugin/bootstrap.py","title":"backend/.venv/lib/python3.12/site-packages/sqlalchemy/testing/plugin/bootstrap.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/sqlalchemy/testing/plugin/bootstrap.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:1882a158c83f8e05f0a644a0a512e781","published":"4/26/2026, 11:03:36 PM","wordCount":205,"token_count_estimate":380,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/sqlalchemy/testing/plugin/bootstrap.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\nbootstrap_file = locals()[\"bootstrap_file\"]\nto_bootstrap = locals()[\"to_bootstrap\"]\n\n\ndef load_file_as_module(name):\n    path = os.path.join(os.path.dirname(bootstrap_file), \"%s.py\" % name)\n\n    spec = importlib.util.spec_from_file_location(name, path)\n    assert spec is not None\n    assert spec.loader is not None\n    mod = importlib.util.module_from_spec(spec)\n    spec.loader.exec_module(mod)\n    return mod\n\n\nif to_bootstrap == \"pytest\":\n    sys.modules[\"sqla_plugin_base\"] = load_file_as_module(\"plugin_base\")\n    sys.modules[\"sqla_plugin_base\"].bootstrapped_as_sqlalchemy = True\n    sys.modules[\"sqla_pytestplugin\"] = load_file_as_module(\"pytestplugin\")\nelse:\n    raise Exception(\"unknown bootstrap: %s\" % to_bootstrap)  # noqa"}}]]