"github://.venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","title":".venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:56487234cfcb6a81d8dd18c29a3ba648","published":"4/26/2026, 11:03:34 PM","wordCount":1217,"token_count_estimate":775,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/tests/test_throw.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\ng = greenlet(f)\n        res = g.switch()\n        self.assertEqual(res, \"ok\")\n        res = g.throw(RuntimeError, \"ciao\")\n        self.assertEqual(res, \"ok\")\n\n    def test_kill(self):\n        def f():\n            switch(\"ok\")\n            switch(\"fail\")\n        g = greenlet(f)\n        res = g.switch()\n        self.assertEqual(res, \"ok\")\n        res = g.throw()\n        self.assertTrue(isinstance(res, greenlet.GreenletExit))\n        self.assertTrue(g.dead)\n        res = g.throw()    # immediately eaten by the already-dead greenlet\n        self.assertTrue(isinstance(res, greenlet.GreenletExit))\n\n    def test_throw_goes_to_original_parent(self):\n        main = greenlet.getcurrent()\n\n        def f1():\n            try:\n                main.switch(\"f1 ready to catch\")\n            except IndexError:\n                return \"caught\"\n            return \"normal exit\"\n\n        def f2():\n            main.switch(\"from f2\")"}},{"id":"6ff1ac92-f0bc-4738-b2ae-38114781dadd","values":[-0.06983065605163574,-0.007560525555163622,0.004418494179844856,-0.011349068023264408,0.10490485280752182,-0.04660807177424431,-0.004499522503465414,0.028509920462965965,0.00349537655711174,0.013706430792808533,0.0891566202044487,-0.06539035588502884,0.021098310127854347,-0.057020749896764755,0.033059779554605484,0.0061512263