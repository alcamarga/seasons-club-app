53824","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:b2432a48be9fe5e0e8105ac334d0ca4b","published":"4/26/2026, 11:03:36 PM","wordCount":235,"token_count_estimate":322,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/tenacity/nap.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\nclass sleep_using_event:\n    \"\"\"Sleep strategy that waits on an event to be set.\"\"\"\n\n    def __init__(self, event: \"threading.Event\") -> None:\n        self.event = event\n\n    def __call__(self, timeout: typing.Optional[float]) -> None:\n        # NOTE(harlowja): this may *not* actually wait for timeout\n        # seconds if the event is set (ie this may eject out early).\n        self.event.wait(timeout=timeout)"}}]]