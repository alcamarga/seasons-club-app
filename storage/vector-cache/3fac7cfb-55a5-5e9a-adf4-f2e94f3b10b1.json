8825489580631256,-0.03221961110830307,-0.002134857466444373,-0.014621117152273655,0.10563703626394272,0.037368644028902054],"metadata":{"id":"ca1bf394-a1a5-4d5e-8136-55533ecf84d7","url":"github://.venv/lib/python3.12/site-packages/pip/_internal/utils/filetypes.py","title":".venv/lib/python3.12/site-packages/pip/_internal/utils/filetypes.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_internal/utils/filetypes.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:d288038269bd7e0d560b6352fb32607b","published":"4/26/2026, 11:03:34 PM","wordCount":103,"token_count_estimate":203,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_internal/utils/filetypes.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\n\"\"\"Filetype information.\n\"\"\"\n\nfrom typing import Tuple\n\nfrom pip._internal.utils.misc import splitext\n\nWHEEL_EXTENSION = \".whl\"\nBZ2_EXTENSIONS: Tuple[str, ...] = (\".tar.bz2\", \".tbz\")\nXZ_EXTENSIONS: Tuple[str, ...] = (\n    \".tar.xz\",\n    \".txz\",\n    \".tlz\",\n    \".tar.lz\",\n    \".tar.lzma\",\n)\nZIP_EXTENSIONS: Tuple[str, ...] = (\".zip\", WHEEL_EXTENSION)\nTAR_EXTENSIONS: Tuple[str, ...] = (\".tar.gz\", \".tgz\", \".tar\")\nARCHIVE_EXTENSIONS = ZIP_EXTENSIONS + BZ2_EXTENSIONS + TAR_EXTENSIONS + XZ_EXTENSIONS\n\n\ndef is_archive_file(name: str) -> bool:\n    \"\"\"Return True if `name` is a considered as an archive file.\"\"\"\n    ext = splitext(name)[1].lower()\n    if ext in ARCHIVE_EXTENSIONS:\n        return True\n    return False"}}]]