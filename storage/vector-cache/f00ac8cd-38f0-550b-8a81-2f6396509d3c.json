6831013262272,-0.03120049275457859],"metadata":{"id":"b3fbec74-d527-480f-940b-aa069386b91d","url":"github://.venv/lib/python3.12/site-packages/greenlet/tests/test_cpp.py","title":".venv/lib/python3.12/site-packages/greenlet/tests/test_cpp.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/tests/test_cpp.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:69534f7ff6b5fdcb20c008d948f55cfb","published":"4/26/2026, 11:03:34 PM","wordCount":727,"token_count_estimate":663,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/tests/test_cpp.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\ndef test_leak_test_exception_switch_and_do_in_g2(self):\n        def raiser():\n            raise ValueError(\"boom\")\n\n        gc.collect()\n        before = objgraph.count(\"greenlet\")\n\n        for _ in range(1000):\n            with self.assertRaises(ValueError):\n                _test_extension_cpp.test_exception_switch_and_do_in_g2(raiser)\n\n        gc.collect()\n        after = objgraph.count(\"greenlet\")\n        leaked = after - before\n        self.assertEqual(0, leaked)\n\n\nif __name__ == '__main__':\n    unittest.main()"}}]]