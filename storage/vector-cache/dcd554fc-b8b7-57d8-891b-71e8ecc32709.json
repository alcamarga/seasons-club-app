029558369889855385,0.07539179921150208,0.03447997197508812,-0.008084540255367756],"metadata":{"id":"ab83cddd-491f-4e7a-81a7-9bf70a7fb0b3","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:9ea1ac0542fe5024cc3a5e977d6aded0","published":"4/26/2026, 11:03:36 PM","wordCount":65,"token_count_estimate":105,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/rich/_timer.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\n\"\"\"\nTimer context manager, only used in debug.\n\n\"\"\"\n\nfrom time import time\n\nimport contextlib\nfrom typing import Generator\n\n\n@contextlib.contextmanager\ndef timer(subject: str = \"time\") -> Generator[None, None, None]:\n    \"\"\"print the elapsed time. (only used in debugging)\"\"\"\n    start = time()\n    yield\n    elapsed = time() - start\n    elapsed_ms = elapsed * 1000\n    print(f\"{subject} elapsed {elapsed_ms:.1f}ms\")"}}]]