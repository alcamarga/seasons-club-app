996560722589493,0.04988867789506912,0.013563308864831924,0.06935327500104904,0.021802108734846115],"metadata":{"id":"959307cb-410c-43b9-a6ec-eec451b3e22a","url":"github://.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","title":".venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:a63a645958bddfe725c77d4069a2ca33","published":"4/26/2026, 11:03:34 PM","wordCount":473,"token_count_estimate":326,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/greenlet/tests/test_version.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\n#! /usr/bin/env python\n\nimport sys\nimport os\nfrom unittest import TestCase as NonLeakingTestCase\n\nimport greenlet\n\n# No reason to run this multiple times under leakchecks,\n# it doesn't do anything.\nclass VersionTests(NonLeakingTestCase):\n    def test_version(self):\n        def find_dominating_file(name):\n            if os.path.exists(name):\n                return name\n\n            tried = []\n            here = os.path.abspath(os.path.dirname(__file__))\n            for i in range(10):\n                up = ['..'] * i\n                path = [here] + up + [name]\n                fname = os.path.join(*path)\n                fname = os.path.abspath(fname)\n                tried.append(fname)\n                if os.path.exists(fname):\n                    return fname\n            raise AssertionError(\"Could not find file \" + name + \"; checked \" + str(tried))"}},{"id":"2097d5b7-190f-4a0c-a0ed-798c9ad48609","values":[-0.0009291358874179423,0.019251195713877678,-0.00008418654761044309,-0.027410563081502914,0.0970822274684906,-0.09913656860589981,-0.05438150838017464,0.032450273633003235,-0.04644092172384262,-0.017331421375274658,0.05992123484611511,-0.00