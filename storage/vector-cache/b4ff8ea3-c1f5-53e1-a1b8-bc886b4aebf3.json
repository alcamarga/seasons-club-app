283110439777374,0.02183317393064499,0.05853620916604996,0.10782276839017868,-0.0015362189151346684],"metadata":{"id":"215cb9ae-aac2-471a-8ea6-f71db35bed6e","url":"github://backend/.venv/lib/python3.12/site-packages/pip/_vendor/urllib3/contrib/_appengine_environ.py","title":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/urllib3/contrib/_appengine_environ.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/pip/_vendor/urllib3/contrib/_appengine_environ.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:1f059b1001c3f294d1fa7ed9563d2f0e","published":"4/26/2026, 11:03:36 PM","wordCount":141,"token_count_estimate":213,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/pip/_vendor/urllib3/contrib/_appengine_environ.py\npublished: 4/26/2026, 11:03:36 PM\n</document_metadata>\n\n\"\"\"\nThis module provides means to detect the App Engine environment.\n\"\"\"\n\nimport os\n\n\ndef is_appengine():\n    return is_local_appengine() or is_prod_appengine()\n\n\ndef is_appengine_sandbox():\n    \"\"\"Reports if the app is running in the first generation sandbox.\n\n    The second generation runtimes are technically still in a sandbox, but it\n    is much less restrictive, so generally you shouldn't need to check for it.\n    see https://cloud.google.com/appengine/docs/standard/runtimes\n    \"\"\"\n    return is_appengine() and os.environ[\"APPENGINE_RUNTIME\"] == \"python27\"\n\n\ndef is_local_appengine():\n    return \"APPENGINE_RUNTIME\" in os.environ and os.environ.get(\n        \"SERVER_SOFTWARE\", \"\"\n    ).startswith(\"Development/\")\n\n\ndef is_prod_appengine():\n    return \"APPENGINE_RUNTIME\" in os.environ and os.environ.get(\n        \"SERVER_SOFTWARE\", \"\"\n    ).startswith(\"Google App Engine/\")\n\n\ndef is_prod_appengine_mvms():\n    \"\"\"Deprecated.\"\"\"\n    return False"}}]]