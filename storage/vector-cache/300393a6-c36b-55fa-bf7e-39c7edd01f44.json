:{"id":"7c5681b4-e311-43e8-be47-cb4e187f1e06","url":"github://.venv/lib/python3.12/site-packages/pip/_vendor/pygments/console.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/pygments/console.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/pygments/console.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:ad68f9f6f91776a5a61b29d90c55b9e9","published":"4/26/2026, 11:03:35 PM","wordCount":358,"token_count_estimate":497,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/pygments/console.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ndef colorize(color_key, text):\n    return codes[color_key] + text + codes[\"reset\"]\n\n\ndef ansiformat(attr, text):\n    \"\"\"\n    Format ``text`` with a color and/or some attributes::\n\n        color       normal color\n        *color*     bold color\n        _color_     underlined color\n        +color+     blinking color\n    \"\"\"\n    result = []\n    if attr[:1] == attr[-1:] == '+':\n        result.append(codes['blink'])\n        attr = attr[1:-1]\n    if attr[:1] == attr[-1:] == '*':\n        result.append(codes['bold'])\n        attr = attr[1:-1]\n    if attr[:1] == attr[-1:] == '_':\n        result.append(codes['underline'])\n        attr = attr[1:-1]\n    result.append(codes[attr])\n    result.append(text)\n    result.append(codes['reset'])\n    return ''.join(result)"}}]]