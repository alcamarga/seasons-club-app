,-0.06370439380407333,0.0019056349992752075,0.0362384095788002,-0.022017551586031914],"metadata":{"id":"0ed13af6-2536-4583-841b-6f07a676998d","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:a16f50f69ae25ef12bdd8ee4662cdbab","published":"4/26/2026, 11:03:35 PM","wordCount":126,"token_count_estimate":233,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_two_greenlets.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\n\"\"\"\nUses a trace function to switch greenlets at unexpected times.\n\nIn the trace function, we switch from the current greenlet to another\ngreenlet, which switches\n\"\"\"\nimport greenlet\n\ng1 = None\ng2 = None\n\nswitch_to_g2 = False\n\ndef tracefunc(*args):\n    print('TRACE', *args)\n    global switch_to_g2\n    if switch_to_g2:\n        switch_to_g2 = False\n        g2.switch()\n    print('\\tLEAVE TRACE', *args)\n\ndef g1_run():\n    print('In g1_run')\n    global switch_to_g2\n    switch_to_g2 = True\n    greenlet.getcurrent().parent.switch()\n    print('Return to g1_run')\n    print('Falling off end of g1_run')\n\ndef g2_run():\n    g1.switch()\n    print('Falling off end of g2')\n\ngreenlet.settrace(tracefunc)\n\ng1 = greenlet.greenlet(g1_run)\ng2 = greenlet.greenlet(g2_run)\n\ng1.switch()\nprint('Falling off end of main')\ng2.switch()"}}]]