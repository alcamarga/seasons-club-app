279801487923,0.005242903251200914,0.032742079347372055,-0.03424800932407379],"metadata":{"id":"ebf3e0c7-2cd7-47df-a306-9deb64c8919e","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_three_greenlets.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_three_greenlets.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_three_greenlets.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:b887f13eace2598b8225281b669478f3","published":"4/26/2026, 11:03:35 PM","wordCount":139,"token_count_estimate":264,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/fail_switch_three_greenlets.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\n\"\"\"\nUses a trace function to switch greenlets at unexpected times.\n\nIn the trace function, we switch from the current greenlet to another\ngreenlet, which switches\n\"\"\"\nimport greenlet\n\ng1 = None\ng2 = None\n\nswitch_to_g2 = False\n\ndef tracefunc(*args):\n    print('TRACE', *args)\n    global switch_to_g2\n    if switch_to_g2:\n        switch_to_g2 = False\n        g2.switch()\n    print('\\tLEAVE TRACE', *args)\n\ndef g1_run():\n    print('In g1_run')\n    global switch_to_g2\n    switch_to_g2 = True\n    from_parent = greenlet.getcurrent().parent.switch()\n    print('Return to g1_run')\n    print('From parent', from_parent)\n\ndef g2_run():\n    #g1.switch()\n    greenlet.getcurrent().parent.switch()\n\ngreenlet.settrace(tracefunc)\n\ng1 = greenlet.greenlet(g1_run)\ng2 = greenlet.greenlet(g2_run)\n\n# This switch didn't actually finish!\n# And if it did, it would raise TypeError\n# because g1_run() doesn't take any arguments.\ng1.switch(1)\nprint('Back in main')\ng1.switch(2)"}}]]