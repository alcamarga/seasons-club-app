formdirs/__main__.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/platformdirs/__main__.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/platformdirs/__main__.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:c448d33d1b3489294db575d8eb9a3903","published":"4/26/2026, 11:03:35 PM","wordCount":272,"token_count_estimate":420,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/platformdirs/__main__.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\nprint(\"\\n-- app dirs (without optional 'version')\")  # noqa: T201\n    dirs = PlatformDirs(app_name, app_author)\n    for prop in PROPS:\n        print(f\"{prop}: {getattr(dirs, prop)}\")  # noqa: T201\n\n    print(\"\\n-- app dirs (without optional 'appauthor')\")  # noqa: T201\n    dirs = PlatformDirs(app_name)\n    for prop in PROPS:\n        print(f\"{prop}: {getattr(dirs, prop)}\")  # noqa: T201\n\n    print(\"\\n-- app dirs (with disabled 'appauthor')\")  # noqa: T201\n    dirs = PlatformDirs(app_name, appauthor=False)\n    for prop in PROPS:\n        print(f\"{prop}: {getattr(dirs, prop)}\")  # noqa: T201\n\n\nif __name__ == \"__main__\":\n    main()"}}]]