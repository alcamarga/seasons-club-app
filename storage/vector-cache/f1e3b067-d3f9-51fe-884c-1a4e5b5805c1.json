0.01887955516576767,-0.05217520892620087,0.03047242946922779,0.016028204932808876,0.07931317389011383,-0.005031000357121229],"metadata":{"id":"ae436bbc-a504-4bf4-ad4e-ed78bce2ff80","url":"github://.venv/lib/python3.12/site-packages/pip/_vendor/pygments/modeline.py","title":".venv/lib/python3.12/site-packages/pip/_vendor/pygments/modeline.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/pygments/modeline.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:20a696c930e74aa52a2413f5d1987fc4","published":"4/26/2026, 11:03:35 PM","wordCount":238,"token_count_estimate":268,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/pygments/modeline.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\n\"\"\"\n    pygments.modeline\n    ~~~~~~~~~~~~~~~~~\n\n    A simple modeline parser (based on pymodeline).\n\n    :copyright: Copyright 2006-2023 by the Pygments team, see AUTHORS.\n    :license: BSD, see LICENSE for details.\n\"\"\"\n\nimport re\n\n__all__ = ['get_filetype_from_buffer']\n\n\nmodeline_re = re.compile(r'''\n    (?: vi | vim | ex ) (?: [<=>]? \\d* )? :\n    .* (?: ft | filetype | syn | syntax ) = ( [^:\\s]+ )\n''', re.VERBOSE)\n\n\ndef get_filetype_from_line(l):\n    m = modeline_re.search(l)\n    if m:\n        return m.group(1)\n\n\ndef get_filetype_from_buffer(buf, max_lines=5):\n    \"\"\"\n    Scan the buffer for modelines and return filetype if one is found.\n    \"\"\"\n    lines = buf.splitlines()\n    for l in lines[-1:-max_lines-1:-1]:\n        ret = get_filetype_from_line(l)\n        if ret:\n            return ret\n    for i in range(max_lines, -1, -1):\n        if i < len(lines):\n            ret = get_filetype_from_line(lines[i])\n            if ret:\n                return ret\n\n    return None"}}]]