79684877396,-0.028763268142938614,-0.035480108112096786,0.07910022884607315,0.09895927459001541,-0.024896666407585144],"metadata":{"id":"748f985b-0522-437d-b147-0ae4a331876e","url":"github://.venv/lib/python3.12/site-packages/pip/__main__.py","title":".venv/lib/python3.12/site-packages/pip/__main__.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/__main__.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:e34b23c8201ea77c305bdb9a54fcba90","published":"4/26/2026, 11:03:34 PM","wordCount":143,"token_count_estimate":228,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/__main__.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nimport os\nimport sys\n\n# Remove '' and current working directory from the first entry\n# of sys.path, if present to avoid using current directory\n# in pip commands check, freeze, install, list and show,\n# when invoked as python -m pip <command>\nif sys.path[0] in (\"\", os.getcwd()):\n    sys.path.pop(0)\n\n# If we are running from a wheel, add the wheel to sys.path\n# This allows the usage python pip-*.whl/pip install pip-*.whl\nif __package__ == \"\":\n    # __file__ is pip-*.whl/pip/__main__.py\n    # first dirname call strips of '/__main__.py', second strips off '/pip'\n    # Resulting path is the name of the wheel itself\n    # Add that to sys.path so we can import pip\n    path = os.path.dirname(os.path.dirname(__file__))\n    sys.path.insert(0, path)\n\nif __name__ == \"__main__\":\n    from pip._internal.cli.main import main as _main\n\n    sys.exit(_main())"}}]]