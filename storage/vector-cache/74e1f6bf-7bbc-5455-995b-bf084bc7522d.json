ata":{"id":"b6289dd6-2478-4200-a633-7a7a82e5f9c5","url":"github://.venv/lib/python3.12/site-packages/pip/_internal/operations/build/wheel_legacy.py","title":".venv/lib/python3.12/site-packages/pip/_internal/operations/build/wheel_legacy.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_internal/operations/build/wheel_legacy.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:4e201c0c1570fda615c171ffe0977510","published":"4/26/2026, 11:03:34 PM","wordCount":713,"token_count_estimate":665,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_internal/operations/build/wheel_legacy.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nreturn text\n\n\ndef get_legacy_build_wheel_path(\n    names: List[str],\n    temp_dir: str,\n    name: str,\n    command_args: List[str],\n    command_output: str,\n) -> Optional[str]:\n    \"\"\"Return the path to the wheel in the temporary build directory.\"\"\"\n    # Sort for determinism.\n    names = sorted(names)\n    if not names:\n        msg = (\"Legacy build of wheel for {!r} created no files.\\n\").format(name)\n        msg += format_command_result(command_args, command_output)\n        logger.warning(msg)\n        return None\n\n    if len(names) > 1:\n        msg = (\n            \"Legacy build of wheel for {!r} created more than one file.\\n\"\n            \"Filenames (choosing first): {}\\n\"\n        ).format(name, names)\n        msg += format_command_result(command_args, command_output)\n        logger.warning(msg)\n\n    return os.path.join(temp_dir, names[0])"}},{"id":"3f142622-a60c-4774-86fa-dc4c07dfc1f5","values":[-0.06297407299280167,-0.0034057158045470715,-0.03691335767507553,-0.01830415427684784,0.039622712880373,-0.09356913715600967,-0.05479040369391441,0.017600614577531815,-0.03500276431441307,-0.0825563296675682,0.07244473695755005,-0.02632930316030979,0.027576809749007225,-0.0335