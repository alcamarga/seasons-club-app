03972190245985985,0.047928210347890854,0.011010869406163692,0.08049072325229645,0.01976463571190834],"metadata":{"id":"35efd9ae-d510-4f5a-bed9-3a46b0b4e476","url":"github://backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","title":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:4134021c8fb095b440cf50465712286c","published":"4/26/2026, 11:03:35 PM","wordCount":473,"token_count_estimate":326,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\n#! /usr/bin/env python\n\nimport sys\nimport os\nfrom unittest import TestCase as NonLeakingTestCase\n\nimport greenlet\n\n# No reason to run this multiple times under leakchecks,\n# it doesn't do anything.\nclass VersionTests(NonLeakingTestCase):\n    def test_version(self):\n        def find_dominating_file(name):\n            if os.path.exists(name):\n                return name\n\n            tried = []\n            here = os.path.abspath(os.path.dirname(__file__))\n            for i in range(10):\n                up = ['..'] * i\n                path = [here] + up + [name]\n                fname = os.path.join(*path)\n                fname = os.path.abspath(fname)\n                tried.append(fname)\n                if os.path.exists(fname):\n                    return fname\n            raise AssertionError(\"Could not find file \" + name + \"; checked \" + str(tried))"}},{"id":"d9f72398-f9be-451b-a682-efeac34a3a2d","values":[-0.007501040585339069,0.02592400647699833,-0.01089612115174532,-0.025316845625638962,0.09091129899024963,-0.10685724765062332,-0.06052165478467941,0.03932742774486542,-0.037210073322057724,-0.02157086879014