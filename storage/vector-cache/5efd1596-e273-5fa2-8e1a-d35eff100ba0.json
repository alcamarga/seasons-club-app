ib/python3.12/site-packages/greenlet/tests/test_version.py","docAuthor":"alcamarga","description":"No description found.","docSource":"backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:4134021c8fb095b440cf50465712286c","published":"4/26/2026, 11:03:35 PM","wordCount":473,"token_count_estimate":326,"text":"<document_metadata>\nsourceDocument: backend/.venv/lib/python3.12/site-packages/greenlet/tests/test_version.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ntry:\n            setup_py = find_dominating_file('setup.py')\n        except AssertionError as e:\n            self.skipTest(\"Unable to find setup.py; must be out of tree. \" + str(e))\n\n\n        invoke_setup = \"%s %s --version\" % (sys.executable, setup_py)\n        with os.popen(invoke_setup) as f:\n            sversion = f.read().strip()\n\n        if not sversion or not sversion[0].isdigit():\n            self.skipTest(\n                \"setup.py --version did not return a version string \"\n                \"(likely a setuptools compatibility issue): \"\n                + repr(sversion[:80])\n            )\n\n        self.assertEqual(sversion, greenlet.__version__)"}}]]