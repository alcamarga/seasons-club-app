fText()\n        if pattern not in self._re_cache:\n            self._re_cache[pattern] = re.compile(pattern, self.flags)\n        self.last = self.match\n        m = self._re_cache[pattern].match(self.data, self.pos)\n        if m is None:\n            return False\n        self.start_pos = m.start()\n        self.pos = m.end()\n        self.match = m.group()\n        return True\n\n    def get_char(self):\n        \"\"\"Scan exactly one char.\"\"\"\n        self.scan('.')"}},{"id":"99ea5ea7-1c58-479e-a247-8159e8de9a66","values":[-0.04757741838693619,0.048916950821876526,-0.08704302459955215,0.014491409994661808,-0.0016248708125203848,-0.07097028195858002,0.033911529928445816,-0.002619285834953189,-0.056720979511737823,-0.02528095804154873,0.04659333452582359,0.002896046731621027,0.06319381296634674,-0.00430027162656188,-0.04186871275305748,0.02135593816637993,-0.08256640285253525,0.05490729957818985,0.05416066572070122,-0.05253620073199272,0.0051155611872673035,0.09209267795085907,0.07999587059020996,0.04421991482377052,-0.025257211178541183,-0.04902750998735428,-0.0875515341758728,0.030893590301275253,-0.026527483016252518,-0.02322579361498356,0.08240043371915817,0.05928419902920723,0.05172060430049896,0.007860417477786541,0.14001648128032684,0.0711287409067154,0.009030980058014393,0.009254124015569687,-0.017692768946290016,0.0620315819978714,0.05279889702796936,-0.04765056073665619,-0.043838415294885635,-0.030894333496689796,-0.07105801999568939,-0.022711480036377907,0.03267538547515869,-0.05844606086611748,-0.013042428530752659,-0.017428642138838768,-0.041796304285526276,-0.034608643501996994,-0.09246348589658737,-0.019158484414219856,0.009636147879064083,-0.012869102880358696,0.016196873039007187,0.054589416831731796,-0.07354719191789627,-0.040991611778736115,-0.04894360154867172,0.03520029038190842,-0.01698468253016472,-0.0031133568845689297,-0.07459147274494171,0.029148153960704803,0.03394315019249916,-0.00309569644741714,0.07516758888959885,-0.0326304063200