# misleading. Solution: instead of using platform, use our code that actually\n# works.\ndef libc_ver() -> Tuple[str, str]:\n    \"\"\"Try to determine the glibc version"}},{"id":"97e12a0f-43f7-4d0a-a9ce-0eaa1b24d661","values":[-0.016708726063370705,0.024716075509786606,0.005813536234200001,-0.019795497879385948,0.0671587809920311,-0.04889579862356186,-0.023245828226208687,-0.021064791828393936,0.01787908375263214,-0.06495343148708344,0.014684943482279778,-0.012038699351251125,-0.04653614014387131,-0.09869527071714401,0.00707769813016057,0.04088551923632622,0.014460070058703423,0.013639681041240692,-0.006806952878832817,-0.0343819260597229,-0.025072360411286354,0.08958111703395844,0.05456231161952019,0.0746796652674675,0.01400088518857956,-0.081048883497715,-0.06552530825138092,-0.028613530099391937,-0.02584896981716156,0.08107730746269226,0.03494466096162796,0.10323075205087662,-0.02492600493133068,-0.0381535142660141,0.19392086565494537,0.051126379519701004,0.010364869609475136,-0.006840551737695932,0.02239658124744892,0.03211117163300514,-0.04261406511068344,-0.02087554894387722,-0.03875676915049553,0.029879886656999588,-0.07476489990949631,0.0799524188041687,-0.007068815175443888,0.033659428358078,0.013232669793069363,-0.005502340383827686,0.007468705531209707,-0.03164239600300789,-0.1399853229522705,-0.018989965319633484,0.07164610922336578,0.018729334697127342,-0.11454448848962784,-0.005540288053452969,-0.04742143675684929,0.05079251527786255,-0.08306945115327835,0.010737685486674309,-0.009893614798784256,-0.011166646145284176,0.009143390692770481,0.04698279872536659,0.04440297558903694,-0.0817098543047905,0.06535322964191437,0.030082739889621735,-0.007902762852609158,-0.017842832952737808,-0.04362880438566208,-0.016070859506726265,-0.08825994282960892,0.054229848086833954,0.03669491037726402,-0.022713227197527885,0.07664856314659119,-0.04891693592071533,-0.07082423567771912,-0.013596643693745136,0.030613573268055916,0.08983661234378815,-0.008196704089641571,-