ng/errors.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:d979213a4f19e679d31ccf5c80a95404","published":"4/26/2026, 11:03:34 PM","wordCount":628,"token_count_estimate":572,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/packaging/errors.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\nUncollected errors are raised normally.\n        \"\"\"\n        yield self\n        self.finalize(msg)\n\n    @contextlib.contextmanager\n    def collect(self, *err_cls: type[Exception]) -> typing.Generator[None, None, None]:\n        \"\"\"\n        Context manager to collect errors into the error list.\n\n        Must be inside loops, as only one error can be collected at a time.\n        \"\"\"\n        error_classes = err_cls or (Exception,)\n        try:\n            yield\n        except ExceptionGroup as error:\n            self.errors.extend(error.exceptions)\n        except error_classes as error:\n            self.errors.append(error)\n\n    def error(\n        self,\n        error: Exception,\n    ) -> None:\n        \"\"\"Add an error to the list.\"\"\"\n        self.errors.append(error)"}}]]