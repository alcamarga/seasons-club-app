lib/python3.12/site-packages/pip/_internal/utils/appdirs.py","title":".venv/lib/python3.12/site-packages/pip/_internal/utils/appdirs.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_internal/utils/appdirs.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:818686149d1f0ae8b5850a198ab94ee5","published":"4/26/2026, 11:03:34 PM","wordCount":240,"token_count_estimate":413,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_internal/utils/appdirs.py\npublished: 4/26/2026, 11:03:34 PM\n</document_metadata>\n\ndef user_config_dir(appname: str, roaming: bool = True) -> str:\n    if sys.platform == \"darwin\":\n        return _macos_user_config_dir(appname, roaming)\n\n    return _appdirs.user_config_dir(appname, appauthor=False, roaming=roaming)\n\n\n# for the discussion regarding site_config_dir locations\n# see <https://github.com/pypa/pip/issues/1733>\ndef site_config_dirs(appname: str) -> List[str]:\n    if sys.platform == \"darwin\":\n        return [_appdirs.site_data_dir(appname, appauthor=False, multipath=True)]\n\n    dirval = _appdirs.site_config_dir(appname, appauthor=False, multipath=True)\n    if sys.platform == \"win32\":\n        return [dirval]\n\n    # Unix-y system. Look in /etc as well.\n    return dirval.split(os.pathsep) + [\"/etc\"]"}}]]