itle":".venv/lib/python3.12/site-packages/pip/_vendor/tenacity/before.py","docAuthor":"alcamarga","description":"No description found.","docSource":".venv/lib/python3.12/site-packages/pip/_vendor/tenacity/before.py","chunkSource":"github://https://github.com/alcamarga/pizzeria-app-core?:81b5c04123fec6cf3d594c3dcd276bd8","published":"4/26/2026, 11:03:35 PM","wordCount":284,"token_count_estimate":366,"text":"<document_metadata>\nsourceDocument: .venv/lib/python3.12/site-packages/pip/_vendor/tenacity/before.py\npublished: 4/26/2026, 11:03:35 PM\n</document_metadata>\n\ndef before_log(logger: \"logging.Logger\", log_level: int) -> typing.Callable[[\"RetryCallState\"], None]:\n    \"\"\"Before call strategy that logs to some logger the attempt.\"\"\"\n\n    def log_it(retry_state: \"RetryCallState\") -> None:\n        if retry_state.fn is None:\n            # NOTE(sileht): can't really happen, but we must please mypy\n            fn_name = \"<unknown>\"\n        else:\n            fn_name = _utils.get_callback_name(retry_state.fn)\n        logger.log(\n            log_level,\n            f\"Starting call to '{fn_name}', \"\n            f\"this is the {_utils.to_ordinal(retry_state.attempt_number)} time calling it.\",\n        )\n\n    return log_it"}}]]